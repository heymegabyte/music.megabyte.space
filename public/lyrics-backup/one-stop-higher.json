:4.72,"e":5.32,"text":"Yeah."},{"s":6.68,"e":8.46,"text":"One stop higher."},{"s":8.96,"e":11.9,"text":"Mm, mm, mm, mm, mm, mm, mm, mm, mm, mm, mm, mm, mm, mm, mm."},{"s":11.9,"e":13.62,"text":"Mike Well on the platform."},{"s":13.92,"e":14.64,"text":"Kane taps the floor."},{"s":14.7,"e":15.98,"text":"One stop north."},{"s":16.08,"e":18.6,"text":"He still wants more from Penn Station home."},{"s":18.6,"e":21.04,"text":"Where the cold nights lean to St. John's Super Kitchen."},{"s":21.24,"e":22.4,"text":"Same room, same dream."},{"s":22.52,"e":23.74,"text":"He freestyles facts."},{"s":23.78,"e":24.98,"text":"He freestyles fire."},{"s":25.22,"e":27.56,"text":"Every line he throws just climbs up higher."},{"s":27.56,"e":30.18,"text":"Watch me move up with the grin so wide."},{"s":30.56,"e":33,"text":"He don't need sight when the vision's inside."},{"s":33.42,"e":34.18,"text":"Hear that laugh."},{"s":34.66,"e":35.32,"text":"Hear that pace."},{"s":35.36,"e":37.98,"text":"Every setback trying, but he won't chase."},{"s":38.14,"e":40.48,"text":"He's got hunger in his chest."},{"s":40.5,"e":43.2,"text":"In the map, nobody else can guess."},{"s":43.42,"e":44.72,"text":"One stop higher."},{"s":45.56,"e":47.3,"text":"One stop higher."},{"s":47.48,"e":49.2,"text":"Mike Well keep going."},{"s":50.3,"e":52.38,"text":"Straight through the fire."},{"s":53.32,"e":55.14,"text":"One stop higher."},{"s":55.82,"e":57.56,"text":"One stop higher."},{"s":57.8,"e":63.1,"text":"From the station floor to the mayor's wire."},{"s":63.46,"e":64.62,"text":"One stop higher."},{"s":68.36,"e":69.74,"text":"One stop higher."},{"s":69.86,"e":72.16,"text":"That's his county college scholarship in hand."},{"s":72.16,"e":73.34,"text":"Books in his backpack."},{"s":73.56,"e":74.64,"text":"Whole city understand."},{"s":74.72,"e":76.92,"text":"He studies the numbers, studies the law."},{"s":77,"e":79.22,"text":"Turns every hard day into awe."},{"s":79.52,"e":80.48,"text":"Blind, not broken."},{"s":80.56,"e":81.74,"text":"He moves with soul."},{"s":81.86,"e":84.3,"text":"Turned a soup line mile into a city goal."},{"s":84.3,"e":86.92,"text":"From the rail to the belly, from the block to the booth."},{"s":87.04,"e":88.22,"text":"He don't just speak hope."},{"s":88.28,"e":89.58,"text":"He delivers the truth."},{"s":89.94,"e":90.94,"text":"Hear that laugh."},{"s":91.2,"e":92.1,"text":"Hear that pace."},{"s":92.12,"e":94.74,"text":"Every setback trying, but he won't chase."},{"s":94.96,"e":97.24,"text":"He's got hunger in his chest."},{"s":97.24,"e":99.98,"text":"In the map, nobody else can guess."},{"s":100.18,"e":101.56,"text":"One stop higher."},{"s":102.4,"e":104.04,"text":"One stop higher."},{"s":104.26,"e":106.02,"text":"Mike Well keep going."},{"s":107.14,"e":109.08,"text":"Straight through the fire."},{"s":110.2,"e":111.9,"text":"One stop higher."},{"s":112.9,"e":114.34,"text":"One stop higher."},{"s":114.6,"e":119.42,"text":"From the station floor to the mayor's wire."},{"s":120.08,"e":121.98,"text":"One stop higher."},{"s":122.78,"e":124.36,"text":"One stop higher."},{"s":124.86,"e":127.02,"text":"They said, wait your turn."},{"s":127.56,"e":129.62,"text":"He said, watch me learn."},{"s":130.2,"e":132.26,"text":"They said, take the low road."},{"s":132.4,"e":134.92,"text":"He said, I'm built for the climb."},{"s":135.34,"e":140.14,"text":"Now the whole town knows how the young king grows."},{"s":140.14,"e":143,"text":"One train ride, one bold dream."},{"s":143.26,"e":145.82,"text":"One name up on the front line."},{"s":149.5,"e":150.62,"text":"One stop higher."},{"s":151.66,"e":153.08,"text":"One stop higher."},{"s":153.32,"e":155.02,"text":"Mike Well keep going."},{"s":155.82,"e":158.06,"text":"Straight through the fire."},{"s":159.46,"e":160.8,"text":"One stop higher."},{"s":162.06,"e":163.32,"text":"One stop higher."},{"s":163.4,"e":168.3,"text":"From the station floor to the mayor's wire."},{"s":169.3,"e":171.08,"text":"One stop higher."},{"s":171.42,"e":173.56,"text":"One stop higher."},{"s":173.7,"e":178.56,"text":"Scholarship shine, let the whole city admire."},{"s":179.3,"e":181.14,"text":"One stop higher."},{"s":184.32,"e":186.3,"text":"One stop higher."}],"duration":191.9600067138672,"source":"whisper","generatedAt":"2026-05-04T22:12:51.413Z","model":"whisper-1"}