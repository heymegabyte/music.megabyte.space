9999389648438,"text":"John's keeps time with weathered hands If"},{"s":30.139999389648438,"e":34.959999084472656,"text":"the walls of the FBI block the"},{"s":34.959999084472656,"e":40.279998779296875,"text":"light that tries to rise Over the"},{"s":40.279998779296875,"e":42.939998626708984,"text":"brick over the door you can't bury"},{"s":42.939998626708984,"e":45.540000915527344,"text":"what came before Oh this church with"},{"s":45.540000915527344,"e":47.86000061035156,"text":"a steady flame I hear the warning"},{"s":47.86000061035156,"e":50.279998779296875,"text":"call its name And when the shadow"},{"s":50.279998779296875,"e":52.5,"text":"leans too long the ground starts singing"},{"s":52.5,"e":55.099998474121094,"text":"like a song You can stack your"},{"s":55.099998474121094,"e":57.400001525878906,"text":"steel up high but the truth won't"},{"s":57.400001525878906,"e":59.279998779296875,"text":"stay tonight"},{"s":60.619998931884766,"e":65.0199966430664,"text":"If the light gets blocked the towers"},{"s":65.0199966430664,"e":66.04000091552734,"text":"rise"},{"s":70.69000244140625,"e":74.63999938964844,"text":"St John still speaks through dust and"},{"s":74.63999938964844,"e":83.0999984741211,"text":"signs St John's Soup Kitchen Covered with"},{"s":83.0999984741211,"e":85.73999786376953,"text":"prophecy Covered with prophecy"},{"s":89.33999633789062,"e":93.05999755859375,"text":"On marked steps and chipstone stairs"},{"s":94.68000030517578,"e":99.4000015258789,"text":"people bring their hunger there Soup and"},{"s":99.4000015258789,"e":102.19999694824219,"text":"bowls and folded coats"},{"s":103.5,"e":106.9800033569336,"text":"Quiet prayers and battered notes"},{"s":108.23999786376953,"e":110.5999984741211,"text":"If the watchers crowd the sky and"},{"s":110.5999984741211,"e":113.26000213623047,"text":"steal the morning from our eyes There's"},{"s":113.26000213623047,"e":115.4800033569336,"text":"a name carved deep in time and"},{"s":115.4800033569336,"e":118.22000122070312,"text":"it won't be erased tonight You can"},{"s":118.22000122070312,"e":120.5999984741211,"text":"pair the dark with stone you can"},{"s":120.5999984741211,"e":122.83999633789062,"text":"name the night your own But the"},{"s":122.83999633789062,"e":125.13999938964844,"text":"old bells know the way through the"},{"s":125.13999938964844,"e":130.27999877929688,"text":"fear and through the grave If the"},{"s":130.27999877929688,"e":134.3800048828125,"text":"light gets blocked the towers rise"},{"s":138.60000610351562,"e":142.97999572753906,"text":"St John still speaks through dust and"},{"s":142.97999572753906,"e":151.83999633789062,"text":"signs St John's Soup Kitchen Covered with"},{"s":151.83999633789062,"e":152.1199951171875,"text":"prophecy"},{"s":162.97999572753906,"e":167.6199951171875,"text":"Let the first red ray come back"},{"s":168.44000244140625,"e":173.89999389648438,"text":"Oversoot and broken tracks What was fed"},{"s":173.89999389648438,"e":178.66000366210938,"text":"to every soul will not be lost"},{"s":178.66000366210938,"e":181.66000366210938,"text":"to what they hold And if they"},{"s":181.66000366210938,"e":187.17999267578125,"text":"build let them build The old words"},{"s":187.17999267578125,"e":192.13999938964844,"text":"outlast the chill I hear new words"},{"s":192.13999938964844,"e":197.8800048828125,"text":"say it clear The dawn is still"},{"s":197.8800048828125,"e":199.1999969482422,"text":"here"},{"s":202.24000549316406,"e":206.0399932861328,"text":"If the light gets blocked the towers"},{"s":206.0399932861328,"e":207.13999938964844,"text":"rise"},{"s":212.17999267578125,"e":215.60000610351562,"text":"St John still speaks through dust and"},{"s":215.60000610351562,"e":221.4600067138672,"text":"signs St John's Soup Kitchen Covered with"},{"s":221.4600067138672,"e":221.4600067138672,"text":"prophecy"},{"s":224.36000061035156,"e":226.17999267578125,"text":"Covered with prophecy"},{"s":228.63999938964844,"e":231,"text":"Covered with prophecy"}],"duration":242.39999389648438}