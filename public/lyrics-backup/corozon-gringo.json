    {
      "s": 38.099998474121094,
      "e": 45.220001220703125,
      "text": "a subir La fiebre del barrio Dentro"
    },
    {
      "s": 45.220001220703125,
      "e": 49.68000030517578,
      "text": "de mí Chimba para el grande gringo"
    },
    {
      "s": 49.68000030517578,
      "e": 54.70000076293945,
      "text": "Bandito de tu corazón Chimba para Chimba"
    },
    {
      "s": 54.70000076293945,
      "e": 57.86000061035156,
      "text": "para el grande gringo Bandito de tu"
    },
    {
      "s": 57.86000061035156,
      "e": 62.31999969482422,
      "text": "corazón Báilame cerquita baby sin explicación Chimba"
    },
    {
      "s": 62.31999969482422,
      "e": 65.4800033569336,
      "text": "Chimba Chimba Chimba Chimba Chimba Chimba Chimba"
    },
    {
      "s": 65.4800033569336,
      "e": 68.27999877929688,
      "text": "para el grande gringo Bandito de tu"
    },
    {
      "s": 68.27999877929688,
      "e": 71.18000030517578,
      "text": "corazón Tú llegas suave pero de frente"
    },
    {
      "s": 71.18000030517578,
      "e": 72.91999816894531,
      "text": "Como un secreto que muerde la gente"
    },
    {
      "s": 72.91999816894531,
      "e": 74.31999969482422,
      "text": "Yo sé que juegas yo sé que"
    },
    {
      "s": 74.31999969482422,
      "e": 76.31999969482422,
      "text": "enciendes Y lo que toca nunca se"
    },
    {
      "s": 76.31999969482422,
      "e": 77.66000366210938,
      "text": "pierde Dime si vamos que yo estoy"
