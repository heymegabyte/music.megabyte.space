  "lines": [
    {
      "s": 5.860000133514404,
      "e": 10.479999542236328,
      "text": "Te vi pasar por mi callejón Con"
    },
    {
      "s": 10.479999542236328,
      "e": 14.260000228881836,
      "text": "esa risa de provocación Yo me hice"
    },
    {
      "s": 14.260000228881836,
      "e": 17.65999984741211,
      "text": "duro me hice el frío Pero en"
    },
    {
      "s": 17.65999984741211,
      "e": 21.639999389648438,
      "text": "tus ojos me perdí Traes el tumbajo"
    },
    {
      "s": 21.639999389648438,
      "e": 25.200000762939453,
      "text": "de una mala tentación Yo traigo ganas"
    },
    {
      "s": 25.200000762939453,
      "e": 28.479999542236328,
      "text": "de romper el control Si tú me"
