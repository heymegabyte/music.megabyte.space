"brings","s":170.74,"e":171.14,"line":53},{"w":"you","s":171.14,"e":171.7,"line":53},{"w":"near.","s":171.7,"e":172.3,"line":53}],"lines":[{"s":2.36,"e":6.76,"text":"Don’t just aim at the sky,"},{"s":6.76,"e":12.22,"text":"Pick one light and tell it why."},{"s":15.77,"e":18.72,"text":"Pick one star, know its name,"},{"s":18.72,"e":21.48,"text":"Trace its fire, feed its flame."},{"s":22.58,"e":26.32,"text":"Not “somewhere,” not “someday,”"},{"s":26.24,"e":30.44,"text":"Choose one light and cut your way."},{"s":30.44,"e":32.78,"text":"Pick one star, bright and far,"},{"s":32.78,"e":37.04,"text":"Point your heart at where you are."},{"s":37.4,"e":41.24,"text":"Dreams get real when targets are clear,"},{"s":41.24,"e":44.92,"text":"One true star can pull you near."},{"s":44.92,"e":46.8,"text":"Everybody says, “shoot high,”"},{"s":46.8,"e":48.56,"text":"But they never draw the map."},{"s":48.56,"e":50.6,"text":"They throw wishes at the night,"},{"s":50.6,"e":52.26,"text":"Then wonder where they’re at."},{"s":52.26,"e":54.28,"text":"You need numbers, names, and places,"},{"s":54.28,"e":56.16,"text":"A road with turns and signs."},{"s":56.16,"e":57.86,"text":"Not a foggy constellation,"},{"s":57.86,"e":59.9,"text":"But a mission with a line."},{"s":59.9,"e":61.7,"text":"Say the goal, set the date,"},{"s":61.7,"e":63.54,"text":"Write the steps, lift the weight."},{"s":63.54,"e":65.42,"text":"Make it sharp, make it known,"},{"s":65.42,"e":67.84,"text":"Make that far-off fire your own."},{"s":67.98,"e":70.3,"text":"Pick one star, know its name,"},{"s":70.3,"e":73.94,"text":"Trace its fire, feed its flame."},{"s":73.94,"e":77.68,"text":"Not “somewhere,” not “someday,”"},{"s":77.68,"e":83.06,"text":"Choose one light and cut your way."},{"s":83.06,"e":85.16,"text":"Pick one star, bright and far,"},{"s":85.16,"e":89.06,"text":"Point your heart at where you are."},{"s":89.78,"e":93.8,"text":"Dreams get real when targets are clear,"},{"s":93.8,"e":97.38,"text":"One true star can pull you near."},{"s":97.38,"e":100.12,"text":"Don’t chase every glowing thing,"},{"s":100.12,"e":104.56,"text":"Don’t drift with every spark."},{"s":104.56,"e":108.48,"text":"Some lights only blind your eyes,"},{"s":108.48,"e":112.36,"text":"Some lights lead through dark."},{"s":112.36,"e":114.06,"text":"Pick the one that makes you better,"},{"s":114.06,"e":116.04,"text":"Pick the one that makes you build."},{"s":116.04,"e":117.9,"text":"Pick the one that serves the people,"},{"s":117.9,"e":119.82,"text":"Pick the one that tests your will."},{"s":119.82,"e":122.2,"text":"Then climb, grind, shine, refine,"},{"s":122.12,"e":123.98,"text":"One bright sign inside your mind."},{"s":123.98,"e":125.8,"text":"Fall, crawl, stand, restart,"},{"s":125.8,"e":127.86,"text":"Star in the sky, fire in the heart."},{"s":127.86,"e":131.42,"text":"A vague dream fades in the morning,"},{"s":131.42,"e":135.1,"text":"A clear dream wakes you up."},{"s":135.1,"e":139,"text":"A named star becomes a warning:"},{"s":139,"e":142.76,"text":"“Don’t quit when it gets tough.”"},{"s":142.76,"e":145.3,"text":"Pick one star, know its name,"},{"s":145.3,"e":148.76,"text":"Trace its fire, feed its flame."},{"s":150,"e":152.44,"text":"Not “somewhere,” not “someday,”"},{"s":152.44,"e":157.96,"text":"Choose one light and cut your way."},{"s":157.96,"e":160,"text":"Pick one star, bright and far,"},{"s":160,"e":163.76,"text":"Point your heart at where you are."},{"s":165.76,"e":168.42,"text":"When the whole sky disappears,"},{"s":168.42,"e":172.3,"text":"One true star still brings you near."}],"duration":183.6,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.320Z","stats":{"whisperWords":334,"polishedWords":330,"matched":323,"matchRate":0.979}}