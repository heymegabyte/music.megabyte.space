,"e":109.58,"line":24},{"w":"Wisdom","s":110.03,"e":110.56,"line":25},{"w":"deep","s":110.56,"e":111.02,"line":25},{"w":"and","s":111.02,"e":111.5,"line":25},{"w":"hearts","s":111.5,"e":111.84,"line":25},{"w":"still","s":111.84,"e":112.38,"line":25},{"w":"learning.","s":112.38,"e":113.06,"line":25},{"w":"Not","s":113.06,"e":113.58,"line":26},{"w":"half-measure,","s":114.14,"e":114.54,"line":26},{"w":"but","s":114.58,"e":115.28,"line":26},{"w":"full","s":115.28,"e":115.82,"line":26},{"w":"treasure,","s":115.82,"e":116.26,"line":26},{"w":"Love","s":116.26,"e":117.14,"line":27},{"w":"beyond","s":117.14,"e":117.98,"line":27},{"w":"all","s":117.98,"e":118.74,"line":27},{"w":"earthly","s":118.74,"e":119.22,"line":27},{"w":"measure.","s":119.22,"e":119.86,"line":27},{"w":"Amen,","s":119.86,"e":120.88,"line":28},{"w":"amen,","s":120.9,"e":122.14,"line":28},{"w":"let","s":122.14,"e":122.18,"line":28},{"w":"grace","s":122.18,"e":122.54,"line":28},{"w":"awaken,","s":122.54,"e":123.44,"line":28},{"w":"No","s":123.44,"e":124.1,"line":29},{"w":"one","s":124.1,"e":124.58,"line":29},{"w":"lost","s":124.58,"e":125.02,"line":29},{"w":"and","s":125.02,"e":125.7,"line":29},{"w":"none","s":125.7,"e":125.7,"line":29},{"w":"forsaken.","s":125.7,"e":126.68,"line":29},{"w":"Christ","s":126.68,"e":127.52,"line":30},{"w":"beside","s":127.52,"e":128.48,"line":30},{"w":"the","s":128.48,"e":128.84,"line":30},{"w":"least","s":128.84,"e":129.44,"line":30},{"w":"and","s":129.44,"e":129.74,"line":30},{"w":"small—","s":129.74,"e":130.48,"line":30},{"w":"Mercy,","s":130.48,"e":131.14,"line":31},{"w":"mercy,","s":132.12,"e":132.12,"line":31},{"w":"cover","s":133.12,"e":133.12,"line":31},{"w":"all.","s":133.12,"e":133.94,"line":31}],"lines":[{"s":6.62,"e":13.52,"text":"Lord of mercy, worthy, holy,"},{"s":15.14,"e":22.38,"text":"Hold the hurting, lost, and lonely."},{"s":22.6,"e":28.98,"text":"Feed the needy, lead them sweetly,"},{"s":29.94,"e":36,"text":"Heal the weary, fully, freely."},{"s":37.08,"e":40.16,"text":"Bless the homeless, hopeless, roaming,"},{"s":40.16,"e":44.06,"text":"Guide them safely, softly, homeward."},{"s":44.06,"e":47.32,"text":"Warm the frozen, broken, chosen,"},{"s":47.32,"e":50.4,"text":"Lift the fallen, called, forgiven."},{"s":50.5,"e":54.06,"text":"For the hungry, empty, aching,"},{"s":54.06,"e":57.42,"text":"Bring them bread and grace unshaken."},{"s":57.84,"e":61.26,"text":"For the poor with doors unopened,"},{"s":61.26,"e":64.7,"text":"Bring them hope and hearts awoken."},{"s":64.7,"e":67.9,"text":"For disabled souls still striving,"},{"s":68.3,"e":71.6,"text":"Give them strength and sacred rising."},{"s":71.6,"e":74.92,"text":"Guard their bodies, minds, and spirits,"},{"s":75.28,"e":78.58,"text":"Let them know Your love is nearest."},{"s":78.58,"e":81.58,"text":"Break addiction, shame, affliction,"},{"s":82.14,"e":85.12,"text":"Turn our pity into mission."},{"s":85.12,"e":88.56,"text":"Make us giving, living, serving,"},{"s":89.06,"e":92.56,"text":"More forgiving, less deserving."},{"s":92.56,"e":95.88,"text":"Lord, restore the crushed and crying,"},{"s":95.88,"e":99.32,"text":"Raise the weak who feel like dying."},{"s":99.32,"e":102.68,"text":"Light the street and night and shelter,"},{"s":102.68,"e":106.36,"text":"Be their helper, healer, welcomer."},{"s":106.36,"e":109.58,"text":"Grant us courage, clear and burning,"},{"s":110.03,"e":113.06,"text":"Wisdom deep and hearts still learning."},{"s":113.06,"e":116.26,"text":"Not half-measure, but full treasure,"},{"s":116.26,"e":119.86,"text":"Love beyond all earthly measure."},{"s":119.86,"e":123.44,"text":"Amen, amen, let grace awaken,"},{"s":123.44,"e":126.68,"text":"No one lost and none forsaken."},{"s":126.68,"e":130.48,"text":"Christ beside the least and small—"},{"s":130.48,"e":133.94,"text":"Mercy, mercy, cover all."}],"duration":157.32,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.320Z","stats":{"whisperWords":178,"polishedWords":175,"matched":167,"matchRate":0.954}}