s":[{"s":2.14,"e":4.16,"text":"Father of light,"},{"s":5.54,"e":7.54,"text":"God of mercy,"},{"s":9.16,"e":10.14,"text":"Spirit of truth,"},{"s":11.88,"e":13.18,"text":"Creator known by many names—"},{"s":14.66,"e":15.78,"text":"Hear us now."},{"s":17.02,"e":19,"text":"The Earth is crying,"},{"s":19.68,"e":21.42,"text":"the children are watching,"},{"s":23.26,"e":24.8,"text":"and heaven is waiting"},{"s":24.72,"e":30.72,"text":"for love to stand up."},{"s":31.74,"e":34.7,"text":"No matter the color, no matter the name,"},{"s":34.9,"e":37.58,"text":"No matter the temple, the cross, or the flame,"},{"s":37.66,"e":40.56,"text":"No matter the scripture, the song, or the sound,"},{"s":40.56,"e":43.96,"text":"We need help from above and we need it right now."},{"s":44.18,"e":46.52,"text":"The rivers are choking, the skies turning gray,"},{"s":47.16,"e":49.42,"text":"The innocent suffer while kings disobey,"},{"s":50.12,"e":52.56,"text":"The poor carry burdens the powerful made,"},{"s":52.8,"e":55.48,"text":"And hatred keeps marching in polished parade."},{"s":55.7,"e":59.1,"text":"So we lift up our hands, but we rise from our knees,"},{"s":59.14,"e":61.86,"text":"Prayer without action won’t set the world free,"},{"s":62.16,"e":64.64,"text":"Love is not silent when evil gets loud,"},{"s":64.94,"e":67.86,"text":"Heaven, give us courage to stand as one crowd."},{"s":67.86,"e":72.1,"text":"We put our foot down, no more war in Your name,"},{"s":73.94,"e":77.98,"text":"We put our foot down, no more feeding the flame,"},{"s":79.54,"e":84.02,"text":"We put our foot down, let the hate hit the ground,"},{"s":85.34,"e":92.18,"text":"Restore the order, Lord, restore it right now."},{"s":92.54,"e":94.9,"text":"Clean up the water, clean up the air,"},{"s":95.48,"e":98.1,"text":"Heal every nation with justice and care,"},{"s":98.36,"e":100.94,"text":"No more excuses, no turning around,"},{"s":101.12,"e":105.46,"text":"For love and for life, we put our foot down."},{"s":106.44,"e":109.48,"text":"For the child in the rubble, the bird in the smoke,"},{"s":109.6,"e":112.5,"text":"For the worker exhausted, the family broke,"},{"s":113,"e":115.72,"text":"For the stranger rejected, the prophet ignored,"},{"s":115.98,"e":118.58,"text":"For the Earth You entrusted that we treated like war."},{"s":119,"e":121.5,"text":"Let mercy be thunder, let wisdom be fire,"},{"s":121.94,"e":124.5,"text":"Let peace be the law that the nations require,"},{"s":124.92,"e":127.88,"text":"Let greed lose its crown, let compassion be found,"},{"s":127.96,"e":130.9,"text":"Let every false idol come crashing down."},{"s":130.9,"e":133.9,"text":"If you call Him Jesus, stand up for peace."},{"s":134.04,"e":136.74,"text":"If you call Him Allah, let hatred cease."},{"s":136.9,"e":139.7,"text":"If you call Her Mother, protect the ground."},{"s":139.88,"e":142.86,"text":"If you seek no name, still love out loud."},{"s":142.86,"e":146.08,"text":"Every race, every creed, every soul, every town,"},{"s":146.08,"e":149.08,"text":"This is the moment we put our foot down."},{"s":149.08,"e":152.06,"text":"Against every weapon, every poisoned stream,"},{"s":152.2,"e":154.88,"text":"Against every lie killing somebody’s dream."},{"s":154.88,"e":159.06,"text":"We put our foot down, no more war in Your name,"},{"s":160.36,"e":164.84,"text":"We put our foot down, no more feeding the flame,"},{"s":166.36,"e":171.1,"text":"We put our foot down, let the hate hit the ground,"},{"s":173.22,"e":179.22,"text":"Restore the order, Lord, restore it right now."},{"s":179.22,"e":181.9,"text":"Clean up the water, clean up the air,"},{"s":182.34,"e":185.08,"text":"Heal every nation with justice and care,"},{"s":185.36,"e":187.88,"text":"No more excuses, no turning around,"},{"s":188.1,"e":192.76,"text":"For love and for life, we put our foot down."},{"s":193.6,"e":197.06,"text":"Make us brave enough to protect what is holy."},{"s":198.54,"e":200.28,"text":"Make us humble enough to change."},{"s":200.98,"e":203.64,"text":"Make us strong enough to stop the violence."},{"s":204.72,"e":207.34,"text":"Make us clean enough to heal the Earth."},{"s":208.3,"e":210.14,"text":"Let peace have power."},{"s":211.28,"e":213.16,"text":"Let love have law."},{"s":214.66,"e":215.7,"text":"Let the world remember"},{"s":215.7,"e":218,"text":"why it was made"}],"duration":233.04,"source":"whisper-aligned","generatedAt":"2026-05-30T01:57:12.502Z","stats":{"whisperWords":460,"polishedWords":457,"matched":451,"matchRate":0.987}}