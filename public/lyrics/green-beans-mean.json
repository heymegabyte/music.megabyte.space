{"w":"John's","s":169.84,"e":170.6,"line":53},{"w":"in","s":170.6,"e":171.04,"line":53},{"w":"the","s":171.04,"e":171.32,"line":53},{"w":"bloodstream","s":171.32,"e":172.1,"line":53},{"w":"Homeless","s":172.1,"e":173.06,"line":54},{"w":"poets","s":173.06,"e":173.74,"line":54},{"w":"on","s":173.74,"e":174.2,"line":54},{"w":"the","s":174.2,"e":174.54,"line":54},{"w":"stream","s":174.54,"e":174.96,"line":54},{"w":"We","s":175.28,"e":175.76,"line":55},{"w":"rise","s":175.76,"e":176.14,"line":55},{"w":"up,","s":176.14,"e":176.72,"line":55},{"w":"we","s":176.72,"e":177.46,"line":55},{"w":"gleam","s":177.46,"e":178,"line":55}],"lines":[{"s":21.9,"e":24.2,"text":"Greens on the plate, got a grudge in the pan"},{"s":24.2,"e":27,"text":"String beans looking like they came with a plan"},{"s":27,"e":29.74,"text":"Mash on the side, butter slick on the spoon"},{"s":29.74,"e":32.52,"text":"I feel a little fierce when I clean up the room"},{"s":32.52,"e":35.44,"text":"You tell me \"take it easy,\" I say \"watch me move\""},{"s":35.44,"e":38.1,"text":"Something in that dinner put a blade in my groove"},{"s":38.1,"e":40.86,"text":"At St. John's, my bro, we don't play small"},{"s":40.86,"e":43.78,"text":"We eat that humble bowl and then we take it all"},{"s":43.78,"e":45.56,"text":"Yeah, they mean, they mean"},{"s":45.6,"e":48.2,"text":"Make a clean machine"},{"s":49.12,"e":50.98,"text":"From a torn-up dream"},{"s":50.98,"e":54.34,"text":"To a crowned-up scene"},{"s":55.26,"e":57.84,"text":"Them green beans make me mean"},{"s":57.84,"e":60.6,"text":"Do my thing, do my thing"},{"s":60.6,"e":63.4,"text":"Mash on the side, real clean"},{"s":63.66,"e":66.36,"text":"Win big, win big"},{"s":66.36,"e":68.92,"text":"Them green beans make me mean"},{"s":68.92,"e":71.66,"text":"St. John's in the bloodstream"},{"s":71.78,"e":74.5,"text":"Homeless poets on the stream"},{"s":74.5,"e":77.36,"text":"We rise up, we gleam"},{"s":77.36,"e":80.26,"text":"There's a man on the curb with a notebook page"},{"s":80.26,"e":82.98,"text":"Writes whole worlds with a coin and a rage"},{"s":82.98,"e":85.68,"text":"There's a woman with a lab coat, chipped at the sleeve"},{"s":85.68,"e":88.46,"text":"Says the cosmos got plans if you learn how to read"},{"s":88.46,"e":91.28,"text":"There's a quiet old thinker by the station wall"},{"s":91.28,"e":94.14,"text":"Says glory comes in when the hungry ones call"},{"s":94.14,"e":96.64,"text":"And from that same bowl, from that same light"},{"s":96.64,"e":99.6,"text":"We get saints, we get schemers, we get fire in the night"},{"s":99.6,"e":101.22,"text":"Yeah, they mean, they mean"},{"s":102,"e":104,"text":"Turn the whole block green"},{"s":104.86,"e":106.68,"text":"From the grease and steam"},{"s":107.66,"e":110.12,"text":"To a crowned-up team"},{"s":110.96,"e":113.66,"text":"Them green beans make me mean"},{"s":113.66,"e":116.44,"text":"Do my thing, do my thing"},{"s":116.44,"e":119.38,"text":"Mash on the side, real clean"},{"s":119.38,"e":122.16,"text":"Win big, win big"},{"s":122.16,"e":124.76,"text":"Them green beans make me mean"},{"s":124.76,"e":127.48,"text":"St. John's in the bloodstream"},{"s":127.48,"e":130.26,"text":"Homeless poets on the stream"},{"s":130.64,"e":133.4,"text":"We rise up, we gleam"},{"s":133.5,"e":136.52,"text":"Infinite pool of glory, bubbling in the tray"},{"s":136.52,"e":139.3,"text":"Every hungry mind gets a place to stay"},{"s":139.3,"e":142.26,"text":"Philosophers talk while the broth runs thick"},{"s":142.3,"e":145,"text":"Scientists and dreamers in the same old mix"},{"s":145,"e":147.18,"text":"I was low, now I'm loud"},{"s":147.18,"e":149.92,"text":"Eyes on the prize, head in the cloud"},{"s":149.92,"e":152.7,"text":"One fork, one shot, one holy scene"},{"s":152.7,"e":155.98,"text":"Green beans hit hard, and they keep me mean"},{"s":155.98,"e":158.38,"text":"Them green beans make me mean"},{"s":158.38,"e":161.1,"text":"Do my thing, do my thing"},{"s":161.1,"e":164.02,"text":"Mash on the side, real clean"},{"s":164.24,"e":166.68,"text":"Win big, win big"},{"s":166.68,"e":169.36,"text":"Them green beans make me mean"},{"s":169.36,"e":172.1,"text":"St. John's in the bloodstream"},{"s":172.1,"e":174.96,"text":"Homeless poets on the stream"},{"s":175.28,"e":178,"text":"We rise up, we gleam"}],"duration":192.04,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.231Z","stats":{"whisperWords":423,"polishedWords":391,"matched":374,"matchRate":0.957}}