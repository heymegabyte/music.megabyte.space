":"Shake","s":173.66,"e":173.72,"line":60},{"w":"their","s":173.72,"e":174.02,"line":60},{"w":"hands,","s":174.02,"e":174.54,"line":60},{"w":"then","s":175.32,"e":175.32,"line":60},{"w":"get","s":175.32,"e":175.44,"line":60},{"w":"’em","s":175.44,"e":175.56,"line":60},{"w":"working.","s":175.56,"e":176.04,"line":60}],"lines":[{"s":2.34,"e":8.5,"text":"Yeah, yeah—"},{"s":8.5,"e":10.48,"text":"KIA Boys, put the keys down,"},{"s":11.78,"e":14.34,"text":"Time to turn the whole street around."},{"s":15.24,"e":18.1,"text":"From the curb to the crown,"},{"s":18.76,"e":21.48,"text":"Let the President shake their hands now."},{"s":23.44,"e":25.48,"text":"KIA Boys need their hands shaken,"},{"s":26.22,"e":28.94,"text":"Not another young life wasted."},{"s":29.4,"e":32.4,"text":"President Trump, bring ’em downtown,"},{"s":32.52,"e":35.64,"text":"Show ’em how kings put the wild nights down."},{"s":37.08,"e":39.14,"text":"No more sirens, no more running,"},{"s":40.72,"e":42.64,"text":"Turn that heat into money coming."},{"s":44.28,"e":46.62,"text":"Shake their hands, let the cameras flash,"},{"s":47.04,"e":50.2,"text":"Turn fast trouble into future cash."},{"s":51.76,"e":53.9,"text":"Young boys flying through the city like ghosts,"},{"s":53.94,"e":55.68,"text":"But the block don’t love who it hurts the most."},{"s":56.04,"e":57.56,"text":"Could’ve been coders, could’ve been chiefs,"},{"s":57.84,"e":59.2,"text":"Could’ve built engines instead of stealing keys."},{"s":59.52,"e":60.72,"text":"Mama been praying by the kitchen light,"},{"s":61.04,"e":62.5,"text":"Saying, “Lord, bring my baby back home tonight.”"},{"s":62.58,"e":64.44,"text":"Now the whole crew standing in a new clean fit,"},{"s":64.54,"e":66.26,"text":"Same wild spark, but they flipped that script."},{"s":66.52,"e":68.12,"text":"Give ’em a job, give ’em a plan,"},{"s":68.28,"e":69.82,"text":"Give ’em a shop and a grown man’s hand."},{"s":69.94,"e":71.52,"text":"Give ’em a reason to stay alive,"},{"s":71.6,"e":73.46,"text":"Turn that street race into a real-life drive."},{"s":73.76,"e":76.14,"text":"KIA Boys need their hands shaken,"},{"s":76.16,"e":78.38,"text":"Not another young life wasted."},{"s":79.52,"e":81.72,"text":"President Trump, bring ’em downtown,"},{"s":82.08,"e":85,"text":"Show ’em how kings put the wild nights down."},{"s":86.76,"e":88.44,"text":"No more sirens, no more running,"},{"s":90.26,"e":92,"text":"Turn that heat into money coming."},{"s":93.62,"e":95.94,"text":"Shake their hands, let the cameras flash,"},{"s":96.4,"e":99.5,"text":"Turn fast trouble into future cash."},{"s":100.42,"e":102.54,"text":"From joyride nights to apprentice days,"},{"s":102.58,"e":104.26,"text":"From viral crime to a righteous phase."},{"s":104.32,"e":105.94,"text":"Same hands that reached for the wheel,"},{"s":105.98,"e":107.68,"text":"Can build, can weld, can close big deals."},{"s":107.82,"e":109.48,"text":"Put ’em in suits, put ’em on stage,"},{"s":109.5,"e":111.22,"text":"Let the whole nation see kids can change."},{"s":111.22,"e":112.92,"text":"Not every rebel gotta end in chains,"},{"s":113.18,"e":114.68,"text":"Some need a handshake and a bigger lane."},{"s":115.16,"e":117.1,"text":"Ain’t no glory in a stolen ride,"},{"s":117.12,"e":118.8,"text":"Real glory is swallowing pride."},{"s":118.86,"e":120.54,"text":"Real power is making it home,"},{"s":120.62,"e":122.22,"text":"Real boss moves mean building your own."},{"s":122.22,"e":124.02,"text":"So line ’em up where the flags wave high,"},{"s":124.1,"e":125.82,"text":"Look ’em dead in their hungry eyes."},{"s":125.86,"e":127.38,"text":"“Son, you’re more than your worst mistake,"},{"s":127.44,"e":129.28,"text":"Now go build something nobody can take.”"},{"s":130.88,"e":134.62,"text":"KIA Boys need their hands shaken,"},{"s":135.74,"e":138.22,"text":"Not another young life wasted."},{"s":138.84,"e":141.54,"text":"President Trump, bring ’em downtown,"},{"s":141.62,"e":144.74,"text":"Show ’em how kings put the wild nights down."},{"s":146.44,"e":148.22,"text":"No more sirens, no more running,"},{"s":149.72,"e":151.7,"text":"Turn that heat into money coming."},{"s":153.3,"e":155.64,"text":"Shake their hands, let the cameras flash,"},{"s":156.12,"e":159.22,"text":"Turn fast trouble into future cash."},{"s":160.9,"e":166.98,"text":"Put the keys down, pick the tools up,"},{"s":167.58,"e":169.96,"text":"Street got cold, but the soul got tough."},{"s":170.26,"e":173.04,"text":"KIA Boys, yeah, the whole world watching—"},{"s":173.66,"e":176.04,"text":"Shake their hands, then get ’em working."}],"duration":193.24,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.305Z","stats":{"whisperWords":451,"polishedWords":422,"matched":382,"matchRate":0.905}}