:49},{"w":"thunderous","s":124.84,"e":125.46,"line":49},{"w":"boom","s":125.46,"e":125.9,"line":49},{"w":"Best","s":125.9,"e":126.3,"line":50},{"w":"in","s":126.3,"e":126.5,"line":50},{"w":"the","s":126.5,"e":126.9,"line":50},{"w":"room,","s":126.9,"e":126.9,"line":50},{"w":"best","s":127.56,"e":127.56,"line":50},{"w":"in","s":127.56,"e":127.8,"line":50},{"w":"the","s":127.8,"e":128.12,"line":50},{"w":"room","s":128.12,"e":128.12,"line":50},{"w":"Never","s":128.22,"e":128.74,"line":51},{"w":"give","s":128.74,"e":129.18,"line":51},{"w":"up,","s":129.18,"e":129.44,"line":51},{"w":"that's","s":129.46,"e":129.56,"line":51},{"w":"the","s":129.66,"e":129.9,"line":51},{"w":"line,","s":129.9,"e":130.08,"line":51},{"w":"that's","s":130.22,"e":130.25,"line":51},{"w":"the","s":130.28,"e":130.8,"line":51},{"w":"rule","s":130.8,"e":130.94,"line":51},{"w":"Best","s":130.94,"e":131.36,"line":52},{"w":"in","s":131.36,"e":131.6,"line":52},{"w":"the","s":131.6,"e":131.96,"line":52},{"w":"room,","s":131.96,"e":131.96,"line":52},{"w":"best","s":132.66,"e":132.66,"line":52},{"w":"in","s":132.66,"e":132.82,"line":52},{"w":"the","s":132.82,"e":133.16,"line":52},{"w":"room","s":133.16,"e":133.16,"line":52},{"w":"I","s":133.36,"e":133.88,"line":53},{"w":"win,","s":133.88,"e":133.88,"line":53},{"w":"then","s":133.9,"e":134.08,"line":53},{"w":"I","s":134.08,"e":134.24,"line":53},{"w":"win,","s":134.24,"e":134.48,"line":53},{"w":"then","s":134.56,"e":134.7,"line":53},{"w":"I","s":134.7,"e":134.96,"line":53},{"w":"win","s":134.96,"e":135.02,"line":53},{"w":"again","s":135.02,"e":135.44,"line":53},{"w":"too","s":135.44,"e":135.82,"line":53}],"lines":[{"s":11.28,"e":14.5,"text":"I came in booked as the best, check the name on the chest"},{"s":14.5,"e":17.08,"text":"Cold hand, hot blood, I was built for the test"},{"s":17.28,"e":19.58,"text":"Mind wide open, got a crown in my head"},{"s":19.58,"e":22.06,"text":"Pineal gleam, I see ten steps ahead"},{"s":22.06,"e":24.6,"text":"I don't chase, I replace, then I sit where they sat"},{"s":24.6,"e":27.14,"text":"Every loss I ever ate turned my spine to a track"},{"s":27.14,"e":29.66,"text":"I got teeth in the grin, got a win in the stride"},{"s":29.66,"e":32.18,"text":"When the room gets dark, I bring fire inside"},{"s":32.18,"e":34.68,"text":"I don't fold for the noise, I don't slow for the doubt"},{"s":34.68,"e":37.54,"text":"If I step in the lane, then the lane gets crowded out"},{"s":37.54,"e":40.4,"text":"Every bar lands clean, every move got a plan"},{"s":40.4,"e":42.94,"text":"I was made for the peak, not the small-pot stance"},{"s":42.96,"e":44.36,"text":"Look at me now"},{"s":44.36,"e":45.48,"text":"Look at me now"},{"s":45.48,"e":46.72,"text":"I bend, then I bounce"},{"s":46.74,"e":47.98,"text":"I rise, no count"},{"s":47.98,"e":50.12,"text":"If I back up, it's tactical"},{"s":50.12,"e":52.66,"text":"If I pause, it's practical"},{"s":52.66,"e":54.94,"text":"Best in the room, best in the room"},{"s":54.94,"e":57.66,"text":"I turn every loss into fuel for the bloom"},{"s":57.66,"e":59.96,"text":"Best in the room, best in the room"},{"s":59.96,"e":62.74,"text":"If I fall, I come back with a thunderous boom"},{"s":62.74,"e":64.96,"text":"Best in the room, best in the room"},{"s":65.12,"e":67.74,"text":"Never give up, that's the line, that's the rule"},{"s":67.74,"e":70.02,"text":"Best in the room, best in the room"},{"s":70.06,"e":72.64,"text":"I win, then I win, then I win again too"},{"s":72.78,"e":75.76,"text":"I got mud on my shoes from the long hard climb"},{"s":75.76,"e":78.28,"text":"Now they point at the sky when I walk that line"},{"s":78.28,"e":80.82,"text":"Every scar on my skin got a story to tell"},{"s":80.82,"e":83.32,"text":"I was down in the pit, now I'm ringing that bell"},{"s":83.32,"e":85.86,"text":"I don't beg for a break, I break through the wall"},{"s":85.86,"e":88.4,"text":"Turn a chokehold to gold when I answer the call"},{"s":88.4,"e":90.9,"text":"If the play needs patience, I wait with a grin"},{"s":90.9,"e":93.34,"text":"If the play needs a strike, then I strike and I win"},{"s":93.5,"e":95.8,"text":"I'm all in, all gas, no fear in the chest"},{"s":95.8,"e":98.36,"text":"When they call me the challenger, I answer as best"},{"s":98.36,"e":100.98,"text":"And if quitting looks useful, then I use it like chess"},{"s":100.98,"e":103.48,"text":"Step back, set the trap, then I finish the quest"},{"s":103.48,"e":104.84,"text":"I learned from the hit"},{"s":104.84,"e":106.06,"text":"I learned from the slip"},{"s":106.06,"e":107.38,"text":"Even a loss can be"},{"s":107.38,"e":108.56,"text":"A blade on the hip"},{"s":108.56,"e":109.9,"text":"So I breathe, then I lock"},{"s":109.9,"e":111.12,"text":"Then I move when it counts"},{"s":111.12,"e":112.4,"text":"What looks like a fall"},{"s":112.4,"e":113.94,"text":"Can be part of the bounce"},{"s":115.7,"e":118.02,"text":"Best in the room, best in the room"},{"s":118.02,"e":120.84,"text":"I turn every loss into fuel for the bloom"},{"s":120.84,"e":123.06,"text":"Best in the room, best in the room"},{"s":123.06,"e":125.9,"text":"If I fall, I come back with a thunderous boom"},{"s":125.9,"e":128.12,"text":"Best in the room, best in the room"},{"s":128.22,"e":130.94,"text":"Never give up, that's the line, that's the rule"},{"s":130.94,"e":133.16,"text":"Best in the room, best in the room"},{"s":133.36,"e":135.82,"text":"I win, then I win, then I win again too"}],"duration":154.76,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.271Z","stats":{"whisperWords":491,"polishedWords":475,"matched":446,"matchRate":0.939}}