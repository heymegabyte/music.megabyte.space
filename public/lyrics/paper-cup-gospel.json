30.72,"line":39},{"w":"a","s":130.72,"e":131.22,"line":39},{"w":"simple","s":131.22,"e":131.94,"line":39},{"w":"promise.","s":131.94,"e":132.82,"line":39},{"w":"One","s":132.82,"e":133.64,"line":40},{"w":"day","s":133.64,"e":133.84,"line":40},{"w":"at","s":133.84,"e":134.1,"line":40},{"w":"a","s":134.1,"e":134.76,"line":40},{"w":"time.","s":134.76,"e":135.24,"line":40},{"w":"One","s":135.24,"e":137.64,"line":41},{"w":"room.","s":137.64,"e":138.4,"line":41},{"w":"One","s":139.26,"e":139.54,"line":42},{"w":"chair.","s":139.54,"e":140.22,"line":42},{"w":"One","s":140.26,"e":141.2,"line":43},{"w":"prayer.","s":141.2,"e":141.88,"line":43},{"w":"Still","s":143.36,"e":144.72,"line":44},{"w":"here.","s":144.72,"e":145.38,"line":44}],"lines":[{"s":2.22,"e":7.98,"text":"I was lucky I walked in,"},{"s":7.98,"e":10.84,"text":"when my road got thin."},{"s":11.42,"e":14.32,"text":"Coffee in a paper cup,"},{"s":14.32,"e":18.88,"text":"truth under my skin."},{"s":20.52,"e":23.76,"text":"Alcoholics Anonymous, miracle in chairs,"},{"s":23.76,"e":27.9,"text":"Strangers telling stories like somebody cares."},{"s":27.9,"e":30.74,"text":"No velvet rope, no perfect face,"},{"s":30.74,"e":34.18,"text":"Just broken people finding grace."},{"s":34.18,"e":37.18,"text":"I heard, “Keep coming,” heard, “Take it slow,”"},{"s":37.18,"e":41.16,"text":"Heard old pain finally let go."},{"s":41.16,"e":44.26,"text":"Not magic like a trick in the air,"},{"s":44.26,"e":47.86,"text":"But spirit moving through the prayer."},{"s":47.86,"e":50.44,"text":"In the rooms with the light on,"},{"s":50.44,"e":53.22,"text":"I learned I wasn’t alone."},{"s":54.76,"e":58.58,"text":"One day, one breath, one hand to hold,"},{"s":58.58,"e":63.38,"text":"A humble heart can still come home."},{"s":63.38,"e":64.68,"text":"AA, AA,"},{"s":65.33,"e":69.46,"text":"A miracle when the soul gets honest."},{"s":69.46,"e":69.46,"text":"AA, AA,"},{"s":69.46,"e":76.38,"text":"Spiritual fire in a simple promise."},{"s":76.38,"e":78.58,"text":"Nobody flexing, nobody crowned,"},{"s":78.58,"e":80.28,"text":"Just truth when the bottle tried to drag us down."},{"s":80.28,"e":81.96,"text":"Higher Power, open door,"},{"s":81.96,"e":83.78,"text":"Knees on the ground but hope on the floor."},{"s":83.78,"e":85.54,"text":"I was lucky that I got to see"},{"s":85.54,"e":87.36,"text":"People become who they’re meant to be."},{"s":87.36,"e":89.2,"text":"Not by ego, not by pride,"},{"s":89.2,"e":91.98,"text":"But by letting something greater inside."},{"s":92,"e":94.06,"text":"Tell the truth, make it right,"},{"s":94.06,"e":95.8,"text":"Call somebody late at night."},{"s":95.8,"e":97.58,"text":"Clean the wreckage, lose the shame,"},{"s":97.58,"e":103.14,"text":"Help the next one do the same."},{"s":103.14,"e":107.36,"text":"In the rooms with the light on,"},{"s":107.36,"e":109.98,"text":"I learned I wasn’t alone."},{"s":111.2,"e":115.04,"text":"One day, one breath, one hand to hold,"},{"s":115.04,"e":118.84,"text":"A humble heart can still come home."},{"s":118.84,"e":120.84,"text":"AA, AA,"},{"s":121.84,"e":125.9,"text":"A miracle when the soul gets honest."},{"s":125.9,"e":125.9,"text":"AA, AA,"},{"s":125.9,"e":132.82,"text":"Spiritual fire in a simple promise."},{"s":132.82,"e":135.24,"text":"One day at a time."},{"s":135.24,"e":138.4,"text":"One room."},{"s":139.26,"e":140.22,"text":"One chair."},{"s":140.26,"e":141.88,"text":"One prayer."},{"s":143.36,"e":145.38,"text":"Still here."}],"duration":146.48,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.318Z","stats":{"whisperWords":244,"polishedWords":252,"matched":237,"matchRate":0.94}}