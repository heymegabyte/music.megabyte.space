170.12,"line":58},{"w":"Christians,","s":170.12,"e":170.86,"line":58},{"w":"every","s":171.04,"e":171.7,"line":58},{"w":"vow,","s":171.7,"e":172.34,"line":58},{"w":"every","s":172.36,"e":173,"line":58},{"w":"crowd","s":173,"e":173.66,"line":58},{"w":"Catholic,","s":174.46,"e":175.4,"line":59},{"w":"Orthodox,","s":175.4,"e":176.6,"line":59},{"w":"Baptist","s":176.6,"e":177.32,"line":59},{"w":"say","s":177.32,"e":178.24,"line":59},{"w":"it","s":178.24,"e":178.62,"line":59},{"w":"loud","s":178.62,"e":179.38,"line":59},{"w":"Pentecostal,","s":179.46,"e":180.38,"line":60},{"w":"Reformed,","s":180.42,"e":181.34,"line":60},{"w":"Methodist","s":181.34,"e":182.12,"line":60},{"w":"all","s":183.02,"e":183.84,"line":60},{"w":"endowed","s":183.84,"e":184.58,"line":60},{"w":"Newark","s":184.58,"e":185.06,"line":61},{"w":"raised","s":185.06,"e":185.44,"line":61},{"w":"me","s":185.44,"e":185.68,"line":61},{"w":"in","s":185.68,"e":185.78,"line":61},{"w":"the","s":185.78,"e":185.96,"line":61},{"w":"fire","s":185.96,"e":186.3,"line":61},{"w":"Macedonia","s":187.06,"e":187.98,"line":61},{"w":"rocked","s":188.5,"e":188.94,"line":61},{"w":"my","s":188.94,"e":189.6,"line":61},{"w":"soul","s":189.6,"e":189.96,"line":61},{"w":"St.","s":189.96,"e":190.4,"line":62},{"w":"John's","s":190.74,"e":190.98,"line":62},{"w":"fed","s":190.98,"e":191.2,"line":62},{"w":"me,","s":191.2,"e":191.98,"line":62},{"w":"Bethel","s":193.36,"e":194.16,"line":62},{"w":"gave","s":194.16,"e":194.38,"line":62},{"w":"the","s":194.38,"e":194.8,"line":62},{"w":"fire,","s":194.8,"e":195.12,"line":62},{"w":"Sacred","s":196.12,"e":196.92,"line":62},{"w":"Heart","s":196.92,"e":197.3,"line":62},{"w":"made","s":198,"e":198.8,"line":62},{"w":"me","s":198.8,"e":199.08,"line":62},{"w":"whole","s":199.08,"e":199.54,"line":62}],"lines":[{"s":8.32,"e":13.44,"text":"From Jerusalem to Newark, we been carrying the cross"},{"s":13.44,"e":16.18,"text":"Every branch, every creed — every gain and every loss"},{"s":16.3,"e":19.04,"text":"Nicaea, Rome, and Azusa — Constantinople's cost"},{"s":19.08,"e":21.72,"text":"Church splits the table but the Spirit never lost"},{"s":21.72,"e":22.22,"text":"---"},{"s":21.72,"e":23.3,"text":"VERSE 1 — THE BEGINNING"},{"s":32.68,"e":35.5,"text":"33 AD the Word put on flesh and bone"},{"s":35.5,"e":38.2,"text":"Paul planted churches from Antioch to Rome"},{"s":38.2,"e":41.3,"text":"Arius said Christ was made — Constantine said no, atone"},{"s":41.78,"e":44.6,"text":"Nicaea 325 — homoousios carved in stone"},{"s":44.66,"e":47.54,"text":"Edict of Milan, persecution done, freedom sewn"},{"s":47.54,"e":50.38,"text":"Anthony hit Egypt's desert, 20 years alone"},{"s":50.7,"e":54.8,"text":"Seraphim of Sarov, 1,000 days of prayer on stone"},{"s":54.8,"e":55.3,"text":"---"},{"s":54.8,"e":55.04,"text":"VERSE 2 — CATHOLIC"},{"s":55.12,"e":57.88,"text":"Cathedral Basilica, French Gothic piercing the sky"},{"s":57.88,"e":61.3,"text":"7 AM every morning — I was always there, not gonna lie"},{"s":61.3,"e":64.38,"text":"Background of the Sopranos — mob on Sunday, kneeled and sighed"},{"s":64.38,"e":66.86,"text":"Tony at communion while he ordered hits inside"},{"s":67.48,"e":69.98,"text":"Transubstantiation — bread becomes the Body, verified"},{"s":70.14,"e":73.18,"text":"Augustine gave original sin, Aquinas gave it pride"},{"s":73.34,"e":76.62,"text":"Confessional: the only booth you walk out lighter than you tried"},{"s":76.62,"e":77.12,"text":"---"},{"s":76.62,"e":76.62,"text":"VERSE 3 — ORTHODOX"},{"s":76.62,"e":80.18,"text":"Great Schism 1054, Rome and Constantinople divide"},{"s":80.24,"e":83.3,"text":"Filioque in the creed — added without vote, who sanctified?"},{"s":83.58,"e":86.42,"text":"Palamas saw the Uncreated Light — hesychasm as guide"},{"s":86.42,"e":89.12,"text":"Theosis is the goal — divinity by grace inside"},{"s":89.12,"e":92,"text":"Jesus Prayer — \"Lord have mercy, sinner\" — that's the ride"},{"s":92,"e":95.02,"text":"Chrysostom \"Golden Mouth\" — exiled twice, never denied"},{"s":95.22,"e":98.88,"text":"Seraphim on the rock — 1,000 days, justified"},{"s":98.88,"e":99.38,"text":"---"},{"s":98.88,"e":98.88,"text":"VERSE 4 — REFORMATION"},{"s":98.88,"e":102.02,"text":"Luther nailed the 95, indulgences he couldn't take no more"},{"s":102.02,"e":105.2,"text":"Sola fide, sola scriptura — faith alone, the Word is core"},{"s":105.2,"e":108.2,"text":"Simul justus et peccator — saint and sinner keeping score"},{"s":108.26,"e":110.98,"text":"Calvin's TULIP — Total depravity to the floor"},{"s":110.98,"e":114.74,"text":"Zwingli stripped the altars, Marburg 1529 still at war"},{"s":114.8,"e":118.14,"text":"Henry VIII just wanted a divorce — Anglican by drawer"},{"s":118.14,"e":122.08,"text":"Wesley strangely warmed — circuit riders, 300K miles more"},{"s":122.08,"e":122.58,"text":"---"},{"s":122.08,"e":123.325,"text":"VERSE 5 — PENTECOSTAL"},{"s":123.74,"e":127.58,"text":"Azusa Street, 1906 — Seymour's one eye saw the fire"},{"s":127.58,"e":130.38,"text":"Son of freed slaves, horse stable, interracial choir"},{"s":130.38,"e":133.48,"text":"COGIC 6.5 million strong, Hammond organ, never tired"},{"s":133.48,"e":136.28,"text":"Word of Faith selling Bentleys — that ain't what God required"},{"s":136.28,"e":140.24,"text":"Real tongues, real gifts, real altar — not for hire"},{"s":140.24,"e":140.74,"text":"---"},{"s":140.24,"e":140.39,"text":"VERSE 6 — NEWARK"},{"s":140.44,"e":143.28,"text":"Macedonia Baptist Church will rock your soul tonight"},{"s":143.28,"e":146.86,"text":"St. John's Soup Kitchen gonna feed you — 700 meals right"},{"s":146.86,"e":149.58,"text":"Zero government dollars — pure love, pure light"},{"s":149.58,"e":152.32,"text":"Bethel in the North Ward gave me the fire to fight"},{"s":152.92,"e":156.6,"text":"AME 1816 — Richard Allen, bought his freedom, built it bright"},{"s":156.9,"e":160.42,"text":"Cathedral Basilica, 7 AM, just me and the priest in sight"},{"s":160.42,"e":165.8,"text":"French Gothic in the Sopranos background — God was always right"},{"s":165.8,"e":168.98,"text":"North Ward, Central Ward — the church held every night"},{"s":168.98,"e":169.48,"text":"---"},{"s":168.98,"e":173.66,"text":"Two billion Christians, every vow, every crowd"},{"s":174.46,"e":179.38,"text":"Catholic, Orthodox, Baptist — say it loud"},{"s":179.46,"e":184.58,"text":"Pentecostal, Reformed, Methodist — all endowed"},{"s":184.58,"e":189.96,"text":"Newark raised me in the fire — Macedonia rocked my soul"},{"s":189.96,"e":199.54,"text":"St. John's fed me, Bethel gave the fire, Sacred Heart made me whole"}],"duration":213.04,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.288Z","stats":{"whisperWords":440,"polishedWords":450,"matched":378,"matchRate":0.84}}