"w":"up","s":199.5,"e":199.88,"line":56},{"w":"No","s":199.88,"e":200.46,"line":57},{"w":"one","s":200.48,"e":200.72,"line":57},{"w":"alone,","s":200.72,"e":201.24,"line":57},{"w":"we","s":201.24,"e":202.24,"line":57},{"w":"rise","s":202.24,"e":202.45,"line":57},{"w":"up","s":202.45,"e":202.66,"line":57},{"w":"Mercy","s":202.66,"e":203.02,"line":58},{"w":"for","s":203.02,"e":203.5,"line":58},{"w":"you,","s":203.5,"e":204.02,"line":58},{"w":"mercy","s":204.42,"e":204.7,"line":58},{"w":"for","s":204.7,"e":205.26,"line":58},{"w":"me","s":205.26,"e":206.08,"line":58},{"w":"Across","s":206.08,"e":206.08,"line":59},{"w":"the","s":206.08,"e":206.08,"line":59},{"w":"cosmos,","s":206.08,"e":206.08,"line":59},{"w":"set","s":206.08,"e":206.08,"line":59},{"w":"us","s":206.08,"e":206.08,"line":59},{"w":"free","s":206.08,"e":222.72,"line":59}],"lines":[{"s":17.48,"e":23.7,"text":"We came in with the weight on low"},{"s":23.7,"e":26.9,"text":"Hearts so cold, but we still glow"},{"s":26.9,"e":30.9,"text":"Found the lost at the edge of the street"},{"s":30.9,"e":34.84,"text":"Now we bring that hope to the weak"},{"s":34.84,"e":36.32,"text":"St. John's Soup Kitchen, line stays long"},{"s":36.32,"e":37.92,"text":"Warm hands, full plates, keepin' faith strong"},{"s":37.92,"e":39.98,"text":"If the night gets thick, we don't break"},{"s":39.98,"e":41.94,"text":"We light the path for the ones awake"},{"s":41.94,"e":43.6,"text":"Lift your eyes, don't fold"},{"s":43.6,"e":44.36,"text":"Mercy hits like gold"},{"s":44.36,"e":45.54,"text":"Love runs deep, love runs far"},{"s":45.54,"e":46.32,"text":"Right through every scar"},{"s":46.32,"e":49.68,"text":"We rise up, we rise up"},{"s":50.2,"e":53.36,"text":"Out of the dark, we rise up"},{"s":54.2,"e":55.68,"text":"St. John's Soup Kitchen"},{"s":55.68,"e":59.54,"text":"Love on the move, we rise up"},{"s":59.54,"e":64.8,"text":"We rise up, we rise up"},{"s":66.34,"e":72.16,"text":"Lost ones, come near, we rise up"},{"s":73.28,"e":83.72,"text":"Christ in the dust, in the dust"},{"s":83.72,"e":84.76,"text":"Freedom for all of us"},{"s":84.76,"e":85.92,"text":"From the block to the borderless sky"},{"s":85.92,"e":87.12,"text":"Got the good news on repeat, on high"},{"s":87.12,"e":88.22,"text":"Every broken name, every hungry hand"},{"s":88.22,"e":90.08,"text":"We keep saying come, you can still stand"},{"s":90.08,"e":92.54,"text":"No chain stay tight when the Savior calls"},{"s":92.54,"e":93.7,"text":"No storm stay proud when the mercy falls"},{"s":93.7,"e":95.14,"text":"We go door to door, mile after mile"},{"s":95.14,"e":97.48,"text":"With the joy that makes the exile smile"},{"s":97.48,"e":99.46,"text":"Lift your eyes, don't fold"},{"s":99.46,"e":100.66,"text":"Mercy hits like gold"},{"s":100.66,"e":102.06,"text":"Love runs deep, love runs far"},{"s":102.06,"e":102.98,"text":"Right through every scar"},{"s":102.98,"e":107.04,"text":"We rise up, we rise up"},{"s":107.78,"e":110.6,"text":"Out of the dark, we rise up"},{"s":111.08,"e":112.94,"text":"St. John's Soup Kitchen"},{"s":113.02,"e":115.62,"text":"Love on the move, we rise up"},{"s":115.62,"e":118.06,"text":"We rise up, we rise up"},{"s":118.8,"e":122.3,"text":"Lost ones, come near, we rise up"},{"s":122.36,"e":125.5,"text":"Christ in the dust, in the dust"},{"s":125.74,"e":138.28,"text":"Freedom for all of us"},{"s":138.28,"e":147.96,"text":"If you feel too far gone, come home"},{"s":147.96,"e":152.16,"text":"If your hands feel empty, you're not alone"},{"s":152.16,"e":154.6,"text":"One voice, one hope, one flame"},{"s":154.6,"e":157.28,"text":"Call His name, call His name"},{"s":157.3,"e":160.7,"text":"Through the black and the blue above"},{"s":160.8,"e":162.56,"text":"We carry mercy, we carry love"},{"s":162.56,"e":165.72,"text":"From this earth to the edge of the stars"},{"s":165.74,"e":168.26,"text":"His light goes out where the hurting are"},{"s":168.26,"e":169.84,"text":"We rise up, we rise up"},{"s":169.84,"e":174.88,"text":"Out of the dark, we rise up"},{"s":174.88,"e":178.82,"text":"St. John's Soup Kitchen"},{"s":178.82,"e":182.16,"text":"Love on the move, we rise up"},{"s":182.26,"e":184.6,"text":"We rise up, we rise up"},{"s":185.32,"e":188.12,"text":"Lost ones, come near, we rise up"},{"s":188.62,"e":193.66,"text":"Christ in the dust, in the dust"},{"s":193.66,"e":196.4,"text":"Freedom for all of us"},{"s":196.4,"e":199.88,"text":"We rise up, we rise up"},{"s":199.88,"e":202.66,"text":"No one alone, we rise up"},{"s":202.66,"e":206.08,"text":"Mercy for you, mercy for me"},{"s":206.08,"e":222.72,"text":"Across the cosmos, set us free"}],"duration":222.72,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.255Z","stats":{"whisperWords":447,"polishedWords":394,"matched":37,"matchRate":0.094}}