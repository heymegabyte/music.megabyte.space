es":[{"s":13.98,"e":16.58,"text":"God of mercy, hear the land,"},{"s":17.08,"e":20.38,"text":"Hold Afghanistan in Your hand."},{"s":20.38,"e":23.5,"text":"Kabul crying, Kandahar sighing,"},{"s":23.9,"e":27.34,"text":"Herat hungry, mothers trying."},{"s":27.44,"e":29.12,"text":"Bread is thin and prices rise,"},{"s":30.34,"e":33.12,"text":"Children search with tired eyes."},{"s":33.74,"e":35.78,"text":"Seventeen million need relief,"},{"s":36.92,"e":39.31,"text":"Turn their hunger into peace."},{"s":41.78,"e":43.34,"text":"Three-point-seven million small,"},{"s":44.44,"e":46.94,"text":"Need Your healing, hear them all."},{"s":48.02,"e":49.86,"text":"Malnutrition, cold condition,"},{"s":50.82,"e":53.38,"text":"Meet their need with swift provision."},{"s":55.08,"e":56.94,"text":"For the girls denied the page,"},{"s":56.94,"e":58.66,"text":"Open schools and break the cage."},{"s":58.66,"e":60.44,"text":"Books and dreams and futures bright,"},{"s":60.44,"e":62.14,"text":"Bring them learning, bring them light."},{"s":62.14,"e":63.9,"text":"For the women trained to heal,"},{"s":63.9,"e":65.66,"text":"Guard their skill and make it real."},{"s":65.66,"e":67.66,"text":"Teachers, nurses, midwives, wise,"},{"s":67.66,"e":69.34,"text":"Keep their calling, let them rise."},{"s":69.34,"e":70.78,"text":"For returnees at the gate,"},{"s":70.78,"e":72.6,"text":"No work, no roof, no food, no plate—"},{"s":72.6,"e":74.36,"text":"Give them shelter, give them rest,"},{"s":74.36,"e":76.18,"text":"Guide the wounded, bless the stressed."},{"s":76.18,"e":78.04,"text":"For the poor with empty hands,"},{"s":78.04,"e":79.78,"text":"Raise up mercy through all lands."},{"s":79.78,"e":81.4,"text":"For the sick, disabled, weak,"},{"s":81.4,"e":83.18,"text":"Be the strength they cannot speak."},{"s":83.18,"e":85.52,"text":"End the fear and end the fighting,"},{"s":85.52,"e":89.24,"text":"Send the rain and send the writing."},{"s":89.72,"e":92.14,"text":"Fields with grain and hearts with grace,"},{"s":93.1,"e":95.68,"text":"Peace in every province, place."},{"s":96.46,"e":99.22,"text":"Let no child be lost to pain,"},{"s":99.22,"e":102.72,"text":"Let no prayer fall down in vain."},{"s":102.72,"e":105.89,"text":"Allah, Lord, Most Merciful One,"},{"s":105.89,"e":110.76,"text":"Warm the night and raise the sun."},{"s":112.54,"e":114.88,"text":"Feed the hungry, free the bound,"},{"s":114.88,"e":116.78,"text":"Lift the fallen from the ground."},{"s":117.12,"e":120.9,"text":"Afghanistan, through dust and flame,"},{"s":121.56,"e":127.36,"text":"May hope come home and bless your name."}],"duration":130.24,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.303Z","stats":{"whisperWords":234,"polishedWords":230,"matched":195,"matchRate":0.848}}