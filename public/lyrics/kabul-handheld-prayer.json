"w":"bless","s":126.04,"e":126.26,"line":57},{"w":"your","s":126.26,"e":126.9,"line":57},{"w":"name","s":126.9,"e":127.38,"line":57}],"lines":[{"s":0,"e":3.76,"text":"Ooh, ooh"},{"s":3.92,"e":7,"text":"Mm, yeah, yeah"},{"s":8.02,"e":10.3,"text":"Ooh, ooh"},{"s":11.28,"e":13.72,"text":"Mm, ooh"},{"s":13.72,"e":16.58,"text":"God have mercy, here the land"},{"s":17.02,"e":20.38,"text":"Whole Afghanistan in your hand"},{"s":20.38,"e":23,"text":"Kabul crying, Kandahar sighing"},{"s":23.62,"e":27.34,"text":"Herod hungry, mothers trying"},{"s":27.34,"e":29.12,"text":"Bread is thin and prices rise"},{"s":29.12,"e":30.96,"text":"Hey, hey, hey, hey"},{"s":30.96,"e":32.72,"text":"Children search with tired eyes"},{"s":32.72,"e":34,"text":"Hey, hey, hey, hey"},{"s":34,"e":35.78,"text":"Seventeen million need relief"},{"s":35.78,"e":37.56,"text":"Eat, eat, eat, eat"},{"s":37.56,"e":39.32,"text":"Turn their hunger into peace"},{"s":39.32,"e":40.84,"text":"Eat, eat, eat, eat"},{"s":40.84,"e":43.3,"text":"Ooh, 3.7 million small"},{"s":43.48,"e":44.78,"text":"Ooh, ooh"},{"s":44.78,"e":46.78,"text":"Need your healing, here them all"},{"s":46.78,"e":48.12,"text":"Ooh, ooh"},{"s":48.16,"e":49.86,"text":"Malnutrition, cold condition"},{"s":49.86,"e":51.42,"text":"Ooh, ooh, ooh, ooh"},{"s":51.42,"e":53.34,"text":"Meet their need with swift provision"},{"s":53.34,"e":54.86,"text":"Ooh, ooh, ooh, ooh"},{"s":54.86,"e":56.94,"text":"But her girls deny the page"},{"s":56.94,"e":58.68,"text":"Open schools and break the cage"},{"s":58.68,"e":60.44,"text":"Books and dreams and futures bright"},{"s":60.44,"e":62.2,"text":"Bring them learning, bring them life"},{"s":62.2,"e":63.9,"text":"For the women trained to heal"},{"s":63.9,"e":65.66,"text":"Guard their skill and make it real"},{"s":65.66,"e":67.66,"text":"Teachers, nurses, midwives, wives"},{"s":67.66,"e":69.34,"text":"Keep their call and let them rise"},{"s":69.34,"e":70.8,"text":"For returnees at the gate"},{"s":70.8,"e":72.6,"text":"No work, no roof, no food, no play"},{"s":72.6,"e":74.36,"text":"Give them shelter, give them rest"},{"s":74.36,"e":76.18,"text":"Guide the wounded, bless the strength"},{"s":76.18,"e":78.04,"text":"For the poor with empty hands"},{"s":78.04,"e":79.78,"text":"Raise up mercy through our lands"},{"s":79.78,"e":81.42,"text":"For the sick, disabled, weak"},{"s":81.42,"e":83.2,"text":"Be the strength, they cannot speak"},{"s":83.2,"e":85.52,"text":"In the fear and in the fighting"},{"s":85.86,"e":86.66,"text":"Ooh, ooh"},{"s":86.66,"e":89.16,"text":"Send the rightness in the righting"},{"s":89.3,"e":90.24,"text":"Ooh, ooh"},{"s":90.24,"e":92.12,"text":"Fields with grain and hearts with grace"},{"s":92.12,"e":93.64,"text":"Squeeze, squeeze, squeeze"},{"s":93.64,"e":95.64,"text":"Peace in every promised place"},{"s":95.64,"e":97.18,"text":"Squeeze, squeeze, squeeze"},{"s":97.18,"e":99.18,"text":"Let no child be lost with pain"},{"s":99.18,"e":102.7,"text":"Let no prayer fall down in vain"},{"s":102.7,"e":106.2,"text":"Our Lord, Lord, most merciful one"},{"s":106.2,"e":110.68,"text":"Warn the night and raise the sun"},{"s":110.68,"e":113.02,"text":"Oh, oh, oh"},{"s":113.02,"e":114.98,"text":"Feed the hungry, free the bound"},{"s":114.98,"e":116.74,"text":"Lift the fallen from the ground"},{"s":117.04,"e":120.72,"text":"Afghanistan, through dust and flame"},{"s":121.56,"e":125.08,"text":"May hope come home"},{"s":125.68,"e":127.38,"text":"And bless your name"}],"duration":130.24000549316406,"source":"whisper","generatedAt":"2026-05-22T02:30:16.580Z","model":"whisper-1"}