,"line":31},{"w":"la","s":93.32,"e":93.86,"line":31},{"w":"chance,","s":93.86,"e":94.4,"line":31},{"w":"Kanye","s":94.4,"e":94.4,"line":32},{"w":"veut","s":94.4,"e":95.14,"line":32},{"w":"sa","s":95.14,"e":95.64,"line":32},{"w":"purée","s":95.64,"e":96.16,"line":32},{"w":"chaude,","s":96.3,"e":96.88,"line":32},{"w":"mon","s":96.88,"e":97.64,"line":32},{"w":"enfant.","s":97.64,"e":98.54,"line":32},{"w":"Outro","s":98.54,"e":102.405,"line":33},{"w":"(parlé,","s":102.405,"e":106.27,"line":33},{"w":"doux)","s":106.27,"e":110.135,"line":33},{"w":"Merci","s":114,"e":114.76,"line":34},{"w":"Paul.","s":114.76,"e":115.24,"line":34},{"w":"Merci","s":115.64,"e":116,"line":34},{"w":"Ye.","s":116,"e":116.22,"line":34},{"w":"À","s":116.58,"e":116.92,"line":34},{"w":"demain,","s":116.92,"e":116.92,"line":34},{"w":"frère.","s":116.92,"e":117.72,"line":34}],"lines":[{"s":8.18,"e":12.28,"text":"Après le dernier niveau d'Alors En Danse,"},{"s":12.28,"e":16,"text":"moi et bZ à la soupe Saint-Jean."},{"s":16.54,"e":20.24,"text":"Stromae a dansé — moi je sers la chance,"},{"s":20.24,"e":23.96,"text":"Kanye veut sa purée — chaude, mon enfant."},{"s":23.96,"e":23.96,"text":"Couplet 1"},{"s":23.96,"e":26.06,"text":"Paul Van Haver nous a donné le rythme,"},{"s":26.06,"e":27.92,"text":"moi je donne le pain à qui n'a pas de rime."},{"s":27.92,"e":30.46,"text":"Bruxelles, Paris, Camden, partout pareil —"},{"s":30.46,"e":32.5,"text":"même musique, même faim, même soleil."},{"s":32.74,"e":34.6,"text":"J'ai dansé toute la nuit, j'ai pleuré toute l'aube,"},{"s":34.6,"e":36.62,"text":"maintenant je porte la louche comme une robe."},{"s":36.62,"e":38.5,"text":"Le frère a faim, le frère a froid —"},{"s":38.5,"e":40.72,"text":"moi et bZ on sert, et on croit."},{"s":40.72,"e":44.48,"text":"Après le dernier niveau d'Alors En Danse,"},{"s":44.48,"e":48.4,"text":"moi et bZ à la soupe Saint-Jean."},{"s":48.82,"e":52.32,"text":"Stromae a dansé — moi je sers la chance,"},{"s":52.32,"e":56,"text":"Kanye veut sa purée — chaude, mon enfant."},{"s":56,"e":56,"text":"Couplet 2"},{"s":56,"e":58.1,"text":"Si Kanye veut sa purée bien chaude,"},{"s":58.1,"e":59.94,"text":"y a rien de plus fin, rien de mieux que le dîner."},{"s":60.04,"e":62.12,"text":"Yeezus dans la queue, Stromae dans les bacs,"},{"s":62.12,"e":64.08,"text":"le Seigneur dans la marmite — pas de slack."},{"s":64.08,"e":66.02,"text":"On danse plus pour fuir, on danse pour servir —"},{"s":66.02,"e":68.04,"text":"chaque cuillère un psaume, chaque bol un soupir."},{"s":68.04,"e":70.1,"text":"bZ avec le tablier, moi avec le sel,"},{"s":70.1,"e":72.12,"text":"on prie sur la vapeur, on bénit la vaisselle."},{"s":72.12,"e":76.28,"text":"Après le dernier niveau, pas de game over —"},{"s":76.28,"e":80.76,"text":"juste la soupe, le frère, et le Sauveur."},{"s":80.76,"e":81.96,"text":"Refrain (chœur seul, puis slam ×2)"},{"s":82.16,"e":86.42,"text":"Après le dernier niveau d'Alors En Danse,"},{"s":86.42,"e":90.3,"text":"moi et bZ à la soupe Saint-Jean."},{"s":90.42,"e":94.4,"text":"Stromae a dansé — moi je sers la chance,"},{"s":94.4,"e":98.54,"text":"Kanye veut sa purée — chaude, mon enfant."},{"s":98.54,"e":110.135,"text":"Outro (parlé, doux)"},{"s":114,"e":117.72,"text":"Merci Paul. Merci Ye. À demain, frère."}],"duration":134.52,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.266Z","stats":{"whisperWords":247,"polishedWords":255,"matched":209,"matchRate":0.82}}