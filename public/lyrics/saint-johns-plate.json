  "lines": [
    {
      "s": 16.079999923706055,
      "e": 20.100000381469727,
      "text": "I sleep where the wind gets loud"
    },
    {
      "s": 20.459999084472656,
      "e": 24.760000228881836,
      "text": "Under that torn up sky My name"
    },
    {
      "s": 24.760000228881836,
      "e": 27.280000686645508,
      "text": "In a paper cup but I still"
    },
    {
      "s": 27.280000686645508,
      "e": 31.780000686645508,
      "text": "Look you in the eye Shoes got"
    },
    {
      "s": 31.780000686645508,
      "e": 34.68000030517578,
      "text": "Holes in the heel pockets got more"
    },
    {
      "s": 34.68000030517578,
      "e": 38.040000915527344,
      "text": "Air than cash Still I walk that"
    },
    {
      "s": 38.040000915527344,
      "e": 41.63999938964844,
      "text": "Long road proud still I don't fold"
    },
    {
      "s": 41.63999938964844,
      "e": 43.900001525878906,
      "text": "To the crash Cause I been knocked"
    },
    {
      "s": 43.900001525878906,
      "e": 47.15999984741211,
      "text": "Down low been counted out and left"
    },
    {
      "s": 47.15999984741211,
      "e": 50.52000045776367,
      "text": "For dead But the day ain't done"
    },
    {
      "s": 50.52000045776367,
      "e": 53.84000015258789,
      "text": "With me I got one more breath"
    },
    {
      "s": 53.84000015258789,
      "e": 57.47999954223633,
      "text": "To spend St John's plate I'm fed"
    },
    {
      "s": 58.58000183105469,
      "e": 63,
      "text": "St John's plate I'm blessed I still"
    },
    {
      "s": 63,
      "e": 67.26000213623047,
      "text": "Have a soul and I still win"
    },
    {
      "s": 67.26000213623047,
      "e": 70.94000244140625,
      "text": "Like this St John's plate I ride"
    },
    {
      "s": 71.80000305175781,
      "e": 76,
      "text": "St John's plate I live They can't"
    },
    {
      "s": 76,
      "e": 81.4000015258789,
      "text": "Take my name when I'm fed like"
    },
    {
      "s": 81.4000015258789,
      "e": 86.5999984741211,
      "text": "This Steamed on a paper tray beans"
    },
    {
      "s": 86.5999984741211,
      "e": 90.94000244140625,
      "text": "And rice in a folded hang Lady"
    },
    {
      "s": 90.94000244140625,
      "e": 94.27999877929688,
      "text": "At the counter say baby eat your"
