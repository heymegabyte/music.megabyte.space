2},{"w":"drop","s":219.64,"e":219.64,"line":62},{"w":"to","s":219.64,"e":219.64,"line":62},{"w":"piano)","s":219.64,"e":219.64,"line":62},{"w":"Five","s":219.64,"e":220.66,"line":63},{"w":"non-negotiables,","s":221.66,"e":223.28,"line":63},{"w":"ten","s":223.32,"e":224.56,"line":63},{"w":"laws","s":224.56,"e":225.72,"line":63},{"w":"to","s":225.72,"e":227.66,"line":63},{"w":"know,","s":227.66,"e":227.66,"line":63},{"w":"fourteen","s":227.66,"e":228.92,"line":64},{"w":"heads","s":228.92,"e":229.8,"line":64},{"w":"on","s":229.8,"e":230.22,"line":64},{"w":"my","s":230.22,"e":230.68,"line":64},{"w":"Rushmore","s":231.12,"e":232.32,"line":64},{"w":"flow.","s":232.32,"e":232.9,"line":64},{"w":"Master","s":232.9,"e":234.2,"line":65},{"w":"the","s":234.2,"e":234.64,"line":65},{"w":"mind","s":234.64,"e":234.82,"line":65},{"w":"'fore","s":234.82,"e":235.2,"line":65},{"w":"you","s":235.2,"e":235.44,"line":65},{"w":"master","s":235.44,"e":235.86,"line":65},{"w":"the","s":235.86,"e":236.52,"line":65},{"w":"room","s":236.52,"e":237.46,"line":65},{"w":"one-mind","s":241,"e":241.4,"line":66},{"w":"problem","s":241.4,"e":241.82,"line":66},{"w":"in","s":241.82,"e":242.14,"line":66},{"w":"the","s":242.14,"e":242.36,"line":66},{"w":"Resolute","s":242.36,"e":243.1,"line":66},{"w":"room.","s":243.1,"e":244.1,"line":66},{"w":"Outro","s":244.1,"e":244.536,"line":67},{"w":"(Eisenhower","s":244.536,"e":244.972,"line":67},{"w":"sample,","s":244.972,"e":245.408,"line":67},{"w":"fading)","s":245.408,"e":245.844,"line":67},{"w":"\"…we","s":246.28,"e":247.68,"line":68},{"w":"must","s":247.68,"e":248.24,"line":68},{"w":"guard","s":248.24,"e":249.32,"line":68},{"w":"against","s":249.32,"e":250.42,"line":68},{"w":"the","s":250.42,"e":251.34,"line":68},{"w":"acquisition","s":251.34,"e":252.18,"line":68},{"w":"of","s":252.18,"e":254.14,"line":68},{"w":"unwarranted","s":254.14,"e":255.58,"line":68},{"w":"influence…\"","s":255.58,"e":258.64,"line":68}],"lines":[{"s":0,"e":7.76,"text":"Five non-negotiables, ten laws to know,"},{"s":7.76,"e":14.14,"text":"fourteen heads on my Rushmore flow."},{"s":14.4,"e":18.78,"text":"Master the mind 'fore you master the room —"},{"s":22.22,"e":25.2,"text":"one-mind problem in the Resolute room."},{"s":25.2,"e":29.34,"text":"Verse 1 — the inner game, the desk, the cabinet"},{"s":29.34,"e":31.46,"text":"Aurelius told me: control what's mine,"},{"s":31.46,"e":33.22,"text":"what ain't mine I leave behind."},{"s":33.22,"e":36.44,"text":"Lincoln wrote the hot letter — never sent it though —"},{"s":36.56,"e":39.56,"text":"Mandela held his face like a pharaoh."},{"s":39.56,"e":43.62,"text":"Eisenhower matrix: urgent ain't important,"},{"s":44.32,"e":47.14,"text":"fifty-year vision, fifteen-minute audit."},{"s":47.14,"e":49.62,"text":"Drucker on abandonment — would you start it today?"},{"s":50.02,"e":51.3,"text":"If you wouldn't, then it's gotta go away."},{"s":51.54,"e":53.98,"text":"Munger flipped it — invert, always invert —"},{"s":53.98,"e":57.58,"text":"ain't tryna be brilliant, just tryna not get hurt."},{"s":57.96,"e":59.62,"text":"Lincoln's cabinet was the rivals all stacked,"},{"s":60.42,"e":62.66,"text":"LKY paid 'em top, jailed 'em when they cracked."},{"s":62.84,"e":65.14,"text":"FDR put Republicans on War and Navy seat —"},{"s":65.14,"e":68.28,"text":"loyalty's a leak when the brain ain't elite."},{"s":70.5,"e":77.16,"text":"Five non-negotiables, ten laws to know,"},{"s":77.16,"e":83.58,"text":"fourteen heads on my Rushmore flow."},{"s":84.1,"e":88.36,"text":"Master the mind 'fore you master the room —"},{"s":91.86,"e":94.92,"text":"one-mind problem in the Resolute room."},{"s":94.92,"e":99.24,"text":"Verse 2 — war, world, frame, stick"},{"s":99.46,"e":101.36,"text":"Sun Tzu whispered: subdue without the swing,"},{"s":101.42,"e":103.2,"text":"win the war 'fore the war's a thing."},{"s":103.2,"e":105.82,"text":"Ike said no to nukes at Dien Bien Phu,"},{"s":105.82,"e":107.36,"text":"no at Suez, no when the U-2 flew."},{"s":107.62,"e":111,"text":"Machiavelli: do the cruelty fast and once,"},{"s":111,"e":113.72,"text":"eighteen months pain then six years of stunts."},{"s":113.88,"e":116.18,"text":"Kissinger — equilibrium over virtue —"},{"s":116.18,"e":120.34,"text":"triangulate Beijing 'fore Moscow can hurt you."},{"s":120.34,"e":124.02,"text":"Strip the ideology, keep the leverage tight,"},{"s":124.02,"e":127.42,"text":"linkage is the language, ambiguity the light."},{"s":127.84,"e":130.78,"text":"FDR fireside, TR bully pulpit,"},{"s":130.78,"e":134.3,"text":"Churchill plain Anglo-Saxon, never dull it."},{"s":134.3,"e":137.54,"text":"Speak soft, big stick, never bluff the line —"},{"s":137.54,"e":141.08,"text":"Great White Fleet ain't fired one round in time."},{"s":141.08,"e":144.08,"text":"Lincoln led when the conscience said go,"},{"s":144.08,"e":150.4,"text":"Mandela waited twenty-seven, soul slow."},{"s":150.4,"e":150.4,"text":"Hook (choir + piano only, then slam)"},{"s":150.4,"e":158.34,"text":"Five non-negotiables, ten laws to know,"},{"s":158.34,"e":163.52,"text":"fourteen heads on my Rushmore flow."},{"s":164.46,"e":168.28,"text":"Master the mind 'fore you master the room —"},{"s":171.68,"e":176.72,"text":"one-mind problem in the Resolute room."},{"s":176.72,"e":178.64,"text":"Verse 3 — the long horizon, the exit, the doctrine"},{"s":178.94,"e":180.44,"text":"TR locked two-thirty million acres in the ground,"},{"s":180.58,"e":182.42,"text":"LKY built the wealth fund, soul of the town."},{"s":182.42,"e":184.16,"text":"Ike warned the complex from inside the gate,"},{"s":184.34,"e":185.9,"text":"Mandela served one and walked at eighty straight."},{"s":185.9,"e":188.02,"text":"Greene said think in decades, act in days —"},{"s":188.02,"e":190.36,"text":"legacy's whatever still runs your way."},{"s":190.36,"e":192.76,"text":"Stoic memento mori at the morning brief,"},{"s":194.26,"e":194.96,"text":"premeditatio malorum, plan the grief."},{"s":195.26,"e":197.18,"text":"Hundred-day mandate, eighteen-month blade,"},{"s":197.18,"e":198.48,"text":"fifty-year file for the moves that I made."},{"s":198.48,"e":201,"text":"Five non-negotiables — write 'em on the desk:"},{"s":201.08,"e":204.68,"text":"master self, hire rivals, win the fight without the mess,"},{"s":204.68,"e":208.04,"text":"own the frame in plain words, leave 'em when they want you —"},{"s":208.04,"e":211.7,"text":"that's the whole doctrine, that's the ghost gon' haunt you."},{"s":213.44,"e":215.16,"text":"Robert Greene watchin', Aurelius co-sign,"},{"s":215.16,"e":219.64,"text":"one-mind problem with a CBO pen, every line."},{"s":219.64,"e":219.64,"text":"Hook (out — choir slam ×2, then drop to piano)"},{"s":219.64,"e":227.66,"text":"Five non-negotiables, ten laws to know,"},{"s":227.66,"e":232.9,"text":"fourteen heads on my Rushmore flow."},{"s":232.9,"e":237.46,"text":"Master the mind 'fore you master the room —"},{"s":241,"e":244.1,"text":"one-mind problem in the Resolute room."},{"s":244.1,"e":245.844,"text":"Outro (Eisenhower sample, fading)"},{"s":246.28,"e":258.64,"text":"\"…we must guard against the acquisition of unwarranted influence…\""}],"duration":277.2,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.259Z","stats":{"whisperWords":517,"polishedWords":502,"matched":393,"matchRate":0.783}}