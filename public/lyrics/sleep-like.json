58},{"w":"Tomorrow","s":216.24,"e":216.96,"line":59},{"w":"is","s":216.96,"e":217.32,"line":59},{"w":"watching","s":217.32,"e":217.92,"line":59},{"w":"you.","s":217.92,"e":218.78,"line":59}],"lines":[{"s":9.36,"e":15.54,"text":"Wake up slow, put the phone on mute,"},{"s":15.68,"e":18.34,"text":"Sun in the window, tie up your shoes."},{"s":18.44,"e":20.84,"text":"Walk like your future is calling your name,"},{"s":21,"e":23.58,"text":"Lift what is heavy, let weakness change."},{"s":23.66,"e":26.06,"text":"Drink clean water, eat from the earth,"},{"s":26.1,"e":28.7,"text":"Count real friends like infinite worth."},{"s":28.7,"e":31.3,"text":"Less poison, more peace, less noise in the room,"},{"s":31.3,"e":33.98,"text":"Plant good habits and watch them bloom."},{"s":34.7,"e":36.12,"text":"The smartest thing ain’t loud,"},{"s":36.32,"e":38.56,"text":"It’s a little thing repeated."},{"s":38.86,"e":41.24,"text":"A quiet seed in the ground,"},{"s":41.24,"e":43.78,"text":"Till the whole life gets completed."},{"s":45.42,"e":49.1,"text":"Sleep like a king, move like you’re free,"},{"s":49.1,"e":54.44,"text":"Love like the wealth is the people you see."},{"s":55.24,"e":59.44,"text":"Save what you can, learn what you don’t,"},{"s":59.9,"e":64.46,"text":"Say what you mean, let go what you won’t."},{"s":64.84,"e":67.4,"text":"Give to the poor, forgive what you can,"},{"s":67.4,"e":70.18,"text":"Build with your hands, become a better man."},{"s":70.18,"e":73.96,"text":"The smartest thing you’ll ever do"},{"s":74.74,"e":78.94,"text":"Is live like tomorrow is watching you."},{"s":80.62,"e":83.12,"text":"Stack up the dollars before they are needed,"},{"s":83.36,"e":85.68,"text":"Compound the good till the dark is defeated."},{"s":85.96,"e":88.44,"text":"Read one page, then write one line,"},{"s":88.56,"e":90.98,"text":"Skill by skill, you sharpen time."},{"s":90.98,"e":93.277,"text":"Don’t chase every shiny thing,"},{"s":93.66,"e":95.62,"text":"Guard your focus like a wedding ring."},{"s":95.64,"e":98.56,"text":"One clean task, one honest prayer,"},{"s":98.76,"e":101.6,"text":"One deep breath in the midnight air."},{"s":102.16,"e":104.32,"text":"The smartest thing ain’t fast,"},{"s":104.42,"e":107.02,"text":"It’s steady through the weather."},{"s":107.06,"e":109.56,"text":"You don’t outrun the past,"},{"s":109.66,"e":112.26,"text":"You build a road that’s better."},{"s":113.44,"e":117.26,"text":"Sleep like a king, move like you’re free,"},{"s":117.26,"e":122.46,"text":"Love like the wealth is the people you see."},{"s":122.5,"e":127.6,"text":"Save what you can, learn what you don’t,"},{"s":128.34,"e":132.66,"text":"Say what you mean, let go what you won’t."},{"s":133.08,"e":135.6,"text":"Give to the poor, forgive what you can,"},{"s":135.6,"e":138.36,"text":"Build with your hands, become a better man."},{"s":138.36,"e":142.48,"text":"The smartest thing you’ll ever do"},{"s":142.96,"e":147.18,"text":"Is live like tomorrow is watching you."},{"s":147.18,"e":149.48,"text":"Call your mother, feed a stranger,"},{"s":149.7,"e":152.1,"text":"Know your limits, sense the danger."},{"s":152.32,"e":154.56,"text":"Choose your circle, choose your aim,"},{"s":154.66,"e":157.18,"text":"Choose the fire, not just the flame."},{"s":157.24,"e":160.14,"text":"Gratitude in a notebook, silence in the storm,"},{"s":160.22,"e":163.12,"text":"Purpose in the service, shelter in the warm."},{"s":163.28,"e":165.26,"text":"Every day you practice peace,"},{"s":165.26,"e":173.28,"text":"Another chain falls, another soul released."},{"s":173.28,"e":177.6,"text":"Sleep like a king, move like you’re free,"},{"s":177.86,"e":182.78,"text":"Love like the wealth is the people you see."},{"s":183.36,"e":187.92,"text":"Save what you can, learn what you don’t,"},{"s":188.54,"e":192.94,"text":"Say what you mean, let go what you won’t."},{"s":193.26,"e":193.26,"text":"Give to the poor, forgive what you can,"},{"s":193.26,"e":198.62,"text":"Build with your hands, become a better man."},{"s":198.62,"e":202.54,"text":"The smartest thing you’ll ever do"},{"s":203.14,"e":207.46,"text":"Is live like tomorrow is watching you."},{"s":207.46,"e":209.58,"text":"Small steps, bright flame,"},{"s":210.36,"e":212.32,"text":"Real love, good name."},{"s":212.34,"e":215.22,"text":"One life, made new—"},{"s":216.24,"e":218.78,"text":"Tomorrow is watching you."}],"duration":219.92,"source":"whisper-aligned","generatedAt":"2026-05-30T01:57:12.511Z","stats":{"whisperWords":423,"polishedWords":433,"matched":404,"matchRate":0.933}}