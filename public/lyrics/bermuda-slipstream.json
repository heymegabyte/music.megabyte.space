9,"line":70}],"lines":[{"s":15.72,"e":19.24,"text":"I left the dock at dawn"},{"s":19.24,"e":21.96,"text":"With a duffel and a chart"},{"s":23.16,"e":25.6,"text":"You laughed and waved goodbye"},{"s":25.6,"e":30.32,"text":"From the stern with a paper heart"},{"s":30.84,"e":33.6,"text":"The captain said, “Stay close”"},{"s":33.6,"e":36.68,"text":"But I like the edge of things"},{"s":37.54,"e":40.1,"text":"I want the kind of map"},{"s":40.1,"e":43.82,"text":"That bends where the blue sea splits"},{"s":46.22,"e":48.32,"text":"Three points on the compass"},{"s":48.32,"e":50.2,"text":"Keep spinning out of line"},{"s":50.28,"e":51.88,"text":"Clouds hang like a warning"},{"s":51.88,"e":53.92,"text":"Still I feel that pull inside"},{"s":53.92,"e":55.62,"text":"If the water starts to whisper"},{"s":55.62,"e":57.24,"text":"And the horizon folds in two"},{"s":57.24,"e":59.18,"text":"I’m already halfway gone"},{"s":59.18,"e":61.08,"text":"When I’m moving toward the blue"},{"s":61.08,"e":63,"text":"Take me down, take me down"},{"s":63,"e":65.68,"text":"To the Bermuda sound"},{"s":65.68,"e":66.347,"text":"(hey, hey)"},{"s":66.68,"e":69.76,"text":"I’m sailing for the seam"},{"s":69.76,"e":75.08,"text":"Where the whole world comes unbound"},{"s":75.46,"e":77.7,"text":"Take me down, take me down"},{"s":77.7,"e":80.22,"text":"Past the charts and the crowd"},{"s":80.22,"e":80.28,"text":"(take me down)"},{"s":81.58,"e":85.48,"text":"If there’s a wormhole out there"},{"s":85.48,"e":87.72,"text":"I’m gonna find it now"},{"s":88.8,"e":92.1,"text":"We passed the wrecked gray buoys"},{"s":92.1,"e":94.88,"text":"And a school of silver bones"},{"s":95.68,"e":98.54,"text":"The radio went static"},{"s":98.54,"e":102.68,"text":"Then it sang in undertones"},{"s":103.46,"e":105.8,"text":"A ring of foam appeared"},{"s":105.8,"e":110.1,"text":"Where the waves should've stayed flat"},{"s":110.24,"e":113.66,"text":"My crew went pale and quiet"},{"s":113.66,"e":117.8,"text":"I just smiled and stared right back"},{"s":119,"e":121.02,"text":"Three points on the compass"},{"s":121.02,"e":122.92,"text":"Keep spinning out of line"},{"s":122.92,"e":124.08,"text":"The moon pulled on the mast"},{"s":124.08,"e":126.6,"text":"Like a hand across my spine"},{"s":126.6,"e":128.32,"text":"If the water starts to shimmer"},{"s":128.32,"e":129.98,"text":"And the sky turns inside out"},{"s":129.98,"e":132.22,"text":"I’m not turning for the shore"},{"s":132.22,"e":133.6,"text":"I’m going through the mouth"},{"s":133.6,"e":135.6,"text":"Take me down, take me down"},{"s":135.6,"e":138.26,"text":"To the Bermuda sound"},{"s":138.26,"e":138.887,"text":"(hey, hey)"},{"s":139.2,"e":143.44,"text":"I’m sailing for the seam"},{"s":143.44,"e":147.9,"text":"Where the whole world comes unbound"},{"s":147.9,"e":150.217,"text":"Take me down, take me down"},{"s":150.217,"e":152.534,"text":"Past the charts and the crowd"},{"s":152.92,"e":154.26,"text":"(take me down)"},{"s":154.26,"e":157.84,"text":"If there’s a wormhole out there"},{"s":157.84,"e":159.92,"text":"I’m gonna find it now"},{"s":176.78,"e":178.78,"text":"There’s a door in the deep"},{"s":178.78,"e":180.26,"text":"And it’s opening slow"},{"s":180.26,"e":182.16,"text":"I see my name in the spray"},{"s":182.16,"e":184.18,"text":"I see tomorrow glow"},{"s":184.18,"e":185.4,"text":"Hold the line"},{"s":185.4,"e":190.12,"text":"Hold the line"},{"s":190.12,"e":193.1,"text":"We’re falling through the tide"},{"s":194.26,"e":196.94,"text":"Take me down, take me down"},{"s":196.94,"e":199.5,"text":"To the Bermuda sound"},{"s":199.5,"e":200.26,"text":"(hey, hey)"},{"s":200.64,"e":204.3,"text":"I’m sailing for the seam"},{"s":204.3,"e":208.56,"text":"Where the whole world comes unbound"},{"s":208.56,"e":211.28,"text":"Take me down, take me down"},{"s":211.28,"e":213.82,"text":"Past the charts and the crowd"},{"s":213.82,"e":213.86,"text":"(take me down)"},{"s":214.9,"e":219.04,"text":"If there’s a wormhole out there"},{"s":219.04,"e":219.74,"text":"I’m gonna find it now"},{"s":219.74,"e":219.74,"text":"Find it now"},{"s":219.74,"e":220.89,"text":"Find it now"}],"duration":237.88,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.274Z","stats":{"whisperWords":353,"polishedWords":386,"matched":315,"matchRate":0.816}}