"w":"earned","s":139.38,"e":140.3,"line":46},{"w":"us","s":140.3,"e":141,"line":46},{"w":"nothing—","s":141,"e":141.8,"line":46},{"w":"Put","s":141.8,"e":142.22,"line":47},{"w":"your","s":142.22,"e":142.48,"line":47},{"w":"whole","s":142.48,"e":142.96,"line":47},{"w":"heart","s":142.96,"e":143.46,"line":47},{"w":"in","s":143.46,"e":143.94,"line":47},{"w":"your","s":143.94,"e":144.64,"line":47},{"w":"hands.","s":144.64,"e":146.3,"line":47},{"w":"No","s":149.18,"e":149.44,"line":48},{"w":"half","s":149.44,"e":149.82,"line":48},{"w":"light.","s":149.82,"e":150.22,"line":48},{"w":"No","s":150.9,"e":151.16,"line":49},{"w":"half","s":151.16,"e":151.56,"line":49},{"w":"soul.","s":151.56,"e":151.96,"line":49},{"w":"No","s":152.12,"e":152.92,"line":50},{"w":"half","s":152.92,"e":153.32,"line":50},{"w":"road","s":153.32,"e":153.78,"line":50},{"w":"to","s":155.74,"e":156,"line":51},{"w":"a","s":156,"e":156.08,"line":51},{"w":"whole","s":156,"e":156.8,"line":51},{"w":"goal.","s":176.78,"e":176.86,"line":51}],"lines":[{"s":1.068,"e":4.96,"text":"All in."},{"s":4.96,"e":8.24,"text":"No halfway hands."},{"s":9.86,"e":11.28,"text":"No almost heart."},{"s":13.2,"e":16.48,"text":"No almost plan."},{"s":33.9,"e":37.16,"text":"I seen half a dream turn dust in the wind,"},{"s":37.16,"e":40.52,"text":"Half a prayer fade before it begin."},{"s":41.04,"e":44.16,"text":"Half a step never crossed that line,"},{"s":44.16,"e":47.68,"text":"Half a truth never saved no mind."},{"s":49.22,"e":50.56,"text":"Half-built bridge, half-lit flame,"},{"s":50.92,"e":52.28,"text":"Half-said love don’t carry no name."},{"s":52.28,"e":54.1,"text":"If I’m gon’ rise, then I’m gon’ climb,"},{"s":54.1,"e":55.9,"text":"Both feet down, whole soul mine."},{"s":55.9,"e":57.56,"text":"No more almost, no more maybe,"},{"s":57.56,"e":59.28,"text":"No more “later,” no more lazy."},{"s":59.28,"e":60.94,"text":"If it’s worth one breath from me,"},{"s":60.94,"e":63.06,"text":"It’s worth the war, it’s worth the bleed."},{"s":63.76,"e":66.08,"text":"Half-measures earned us nothing,"},{"s":66.08,"e":68.48,"text":"Nothing but a colder day."},{"s":68.48,"e":71.12,"text":"If we’re gonna build it, build it,"},{"s":71.12,"e":73.98,"text":"If we’re gonna pray, then pray."},{"s":75.64,"e":79.08,"text":"If we’re gonna love, then love hard,"},{"s":79.08,"e":82.82,"text":"If we’re gonna fight, then stand."},{"s":83.34,"e":86.14,"text":"Half-measures earned us nothing—"},{"s":86.14,"e":89.8,"text":"Put your whole heart in your hands."},{"s":89.8,"e":91.88,"text":"I don’t want a spark, I want the blaze,"},{"s":91.88,"e":93.62,"text":"I don’t want applause, I want the change."},{"s":93.62,"e":95.46,"text":"I don’t want a crown made out of lies,"},{"s":95.46,"e":97.18,"text":"I want the work that makes men rise."},{"s":97.18,"e":98.78,"text":"One clean shot, one true aim,"},{"s":98.78,"e":100.5,"text":"One full heart in a world half-tamed."},{"s":100.5,"e":102.2,"text":"No weak vow, no borrowed spine,"},{"s":102.2,"e":104.16,"text":"I do it all or it ain’t mine."},{"s":104.16,"e":105.94,"text":"All the way through the thunder,"},{"s":105.86,"e":107.66,"text":"All the way through the pain."},{"s":107.66,"e":109.34,"text":"All the way when they wonder"},{"s":109.34,"e":111.12,"text":"Why I still walk through rain."},{"s":111.12,"e":112.9,"text":"Because halfway never healed us,"},{"s":112.9,"e":114.6,"text":"Halfway never freed."},{"s":114.6,"e":116.3,"text":"Whole fire, whole spirit,"},{"s":116.42,"e":119.4,"text":"Whole life, whole deed."},{"s":119.4,"e":121.88,"text":"Half-measures earned us nothing,"},{"s":121.88,"e":124.58,"text":"Nothing but a colder day."},{"s":124.58,"e":126.9,"text":"If we’re gonna build it, build it,"},{"s":126.82,"e":129.62,"text":"If we’re gonna pray, then pray."},{"s":131.3,"e":134.66,"text":"If we’re gonna love, then love hard,"},{"s":134.66,"e":138.44,"text":"If we’re gonna fight, then stand."},{"s":138.98,"e":141.8,"text":"Half-measures earned us nothing—"},{"s":141.8,"e":146.3,"text":"Put your whole heart in your hands."},{"s":149.18,"e":150.22,"text":"No half light."},{"s":150.9,"e":151.96,"text":"No half soul."},{"s":152.12,"e":153.78,"text":"No half road"},{"s":155.74,"e":176.86,"text":"to a whole goal."}],"duration":176.8,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.314Z","stats":{"whisperWords":343,"polishedWords":325,"matched":300,"matchRate":0.923}}