},{"w":"odds,","s":240.68,"e":240.88,"line":57},{"w":"deep","s":240.96,"e":241.34,"line":57},{"w":"rods,","s":241.34,"e":241.62,"line":57},{"w":"struck","s":241.62,"e":241.84,"line":57},{"w":"by","s":241.84,"e":242.18,"line":57},{"w":"God,","s":242.18,"e":242.42,"line":57},{"w":"still","s":242.48,"e":242.72,"line":57},{"w":"I","s":242.72,"e":243.02,"line":57},{"w":"nod.","s":243.02,"e":243.1,"line":57},{"w":"They","s":243.04,"e":243.32,"line":58},{"w":"never","s":243.32,"e":243.72,"line":58},{"w":"favored","s":243.72,"e":244.3,"line":58},{"w":"winning,","s":244.3,"e":244.78,"line":58},{"w":"they","s":244.78,"e":245.44,"line":58},{"w":"favored","s":245.44,"e":245.64,"line":58},{"w":"becoming.","s":245.64,"e":246.32,"line":58},{"w":"They","s":246.32,"e":246.8,"line":59},{"w":"never","s":246.8,"e":247.16,"line":59},{"w":"favored","s":247.16,"e":247.52,"line":59},{"w":"luck,","s":247.52,"e":248.3,"line":59},{"w":"they","s":248.36,"e":249.1,"line":59},{"w":"favored","s":249.1,"e":249.42,"line":59},{"w":"getting","s":249.42,"e":249.94,"line":59},{"w":"up.","s":249.94,"e":250.72,"line":59}],"lines":[{"s":9.21,"e":20.055,"text":"Verse 1"},{"s":30.7,"e":33.96,"text":"Cold bones roll, soul knows, low blows."},{"s":34.28,"e":37.2,"text":"Gold glows, hope goes, crow crows."},{"s":37.2,"e":40.2,"text":"Dice slide, eyes wide, pride died."},{"s":40.2,"e":43.64,"text":"Night lied, tides tried, I survived."},{"s":44,"e":46.42,"text":"Bad chance, sad dance, last stance."},{"s":46.48,"e":49.3,"text":"Black hands, cracked plans, trapped lands."},{"s":49.68,"e":52.62,"text":"Snake eyes, fake skies, great lies."},{"s":52.62,"e":56.1,"text":"Pain flies, faith rises, fate replies."},{"s":56.1,"e":56.18,"text":"Pre-Chorus"},{"s":56.1,"e":59.09,"text":"No win, slow spin, soul grin."},{"s":59.09,"e":62.14,"text":"Thrown thin, grown in, shown within."},{"s":62.14,"e":65.06,"text":"Wrong way, long day, strong clay."},{"s":65.38,"e":67.7,"text":"Lost play, cross-shaped, God-made."},{"s":67.7,"e":68.16,"text":"Chorus"},{"s":68.16,"e":74.18,"text":"Loaded dice, frozen nights, broken lights, chosen fights."},{"s":74.18,"e":80.22,"text":"Never right, never mine, every time, still I shine."},{"s":80.22,"e":85.08,"text":"They don’t favor me, but they’re raising me."},{"s":86.02,"e":91.1,"text":"They keep breaking me, but they’re making me."},{"s":93.32,"e":96.74,"text":"Crooked roll, holy toll, forge my soul, make me whole."},{"s":96.74,"e":99.84,"text":"Bad luck, hard struck, still stuck, still up."},{"s":99.84,"e":102.84,"text":"They don’t favor winning, they favor beginning."},{"s":102.84,"e":107.22,"text":"They don’t favor ease, they favor knees."},{"s":111.88,"e":113.5,"text":"Verse 2"},{"s":117.78,"e":121.12,"text":"House smiles, false aisles, lost miles."},{"s":121.12,"e":124.46,"text":"Dealer grins, sinner wins, thunder spins."},{"s":124.46,"e":127.12,"text":"Cards burn, scars learn, stars turn."},{"s":127.12,"e":130.62,"text":"Tables shake, prayers wake, chains break."},{"s":130.62,"e":133.12,"text":"Low roll, no gold, cold road."},{"s":133.12,"e":136.32,"text":"Deep debt, steep steps, wept sweat."},{"s":136.62,"e":139.6,"text":"No crown, thrown down, ghost town."},{"s":139.6,"e":143.14,"text":"Still found, still sound, still around."},{"s":143.14,"e":143.22,"text":"Pre-Chorus"},{"s":143.14,"e":145.76,"text":"No prize, wise eyes, skies rise."},{"s":145.76,"e":149.04,"text":"Tears dry, fears die, I fly."},{"s":149.04,"e":152.1,"text":"Hard ground, heart pound, grace found."},{"s":152.1,"e":155.04,"text":"Turned around, glory crowned, mercy sounds."},{"s":154.96,"e":155.5,"text":"Chorus"},{"s":155.5,"e":161.36,"text":"Loaded dice, frozen nights, broken lights, chosen fights."},{"s":161.36,"e":167.38,"text":"Never right, never mine, every time, still I shine."},{"s":167.38,"e":172.26,"text":"They don’t favor me, but they’re raising me."},{"s":173.26,"e":178.24,"text":"They keep breaking me, but they’re making me."},{"s":180.64,"e":183.98,"text":"Crooked roll, holy toll, forge my soul, make me whole."},{"s":183.98,"e":187.1,"text":"Bad luck, hard struck, still stuck, still up."},{"s":187.1,"e":190.2,"text":"They don’t favor winning, they favor beginning."},{"s":190.2,"e":194.38,"text":"They don’t favor ease, they favor knees."},{"s":194.38,"e":195.27,"text":"Bridge"},{"s":196.16,"e":199.6,"text":"Let them roll, let them lie, let them die, I rise."},{"s":199.7,"e":202.84,"text":"Let them cheat, let them sneer, let them fear my fire."},{"s":202.9,"e":205.66,"text":"Every curse, every hearse, every worse reversed."},{"s":205.66,"e":208.26,"text":"Every scar, every bar, made me star-burst."},{"s":208.18,"e":211.58,"text":"Final Chorus"},{"s":211.58,"e":217.62,"text":"Loaded dice, sacred price, sacrifice, paradise."},{"s":217.62,"e":222.76,"text":"Never fair, never spared, still prepared, still there."},{"s":222.76,"e":228.5,"text":"They don’t favor treasure, they favor pressure."},{"s":229.33,"e":235.58,"text":"They don’t favor pleasure, they favor measure."},{"s":236.62,"e":240.1,"text":"Crooked bones, holy stones, throne unknown, soul grown."},{"s":240.1,"e":243.1,"text":"Bad odds, deep rods, struck by God, still I nod."},{"s":243.04,"e":246.32,"text":"They never favored winning, they favored becoming."},{"s":246.32,"e":250.72,"text":"They never favored luck, they favored getting up."}],"duration":269.92,"source":"whisper-aligned","generatedAt":"2026-05-30T20:04:38.326Z","stats":{"whisperWords":405,"polishedWords":393,"matched":331,"matchRate":0.842}}