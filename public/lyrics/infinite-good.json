"s":118.8,"e":119.14,"line":33},{"w":"made","s":119.14,"e":119.42,"line":33},{"w":"me","s":119.42,"e":120.5,"line":33},{"w":"whole","s":120.5,"e":121.34,"line":33},{"w":"Hey","s":121.38,"e":121.68,"line":34},{"w":"Ooh","s":122.28,"e":123.68,"line":35},{"w":"Hmm","s":125.72,"e":127.04,"line":36},{"w":"Ooh","s":128.58,"e":129.98,"line":37}],"lines":[{"s":0.2,"e":10.22,"text":"Ooh, a hyper, a hyper intelligent, gray alien."},{"s":12.14,"e":15.14,"text":"Ooh, come from beyond the stars, seeking ultimate power."},{"s":16.4,"e":20.2,"text":"But Christ teaches him the highest power is love without limit."},{"s":21.22,"e":26.16,"text":"He calls down infinite mercy, infinite wisdom, infinite resources,"},{"s":27.1,"e":29.1,"text":"infinite courage and infinite compassion."},{"s":29.74,"e":32.54,"text":"Then pours it into the streets to do infinite good."},{"s":33.58,"e":35.06,"text":"He has to pour what they need."},{"s":35.7,"e":37.52,"text":"Then gives every advantage possible."},{"s":38.04,"e":43.82,"text":"Food, shelter, phone, ID's, job, clean clothes, ride, training, prayer,"},{"s":44.58,"e":46.68,"text":"protection and hope."},{"s":47.44,"e":49.9,"text":"Summon the light, let it flood through the hood."},{"s":50.22,"e":52.4,"text":"Infinite power for infinite good."},{"s":52.92,"e":55.84,"text":"Not for the crown, not misunderstood to our monster,"},{"s":56.22,"e":57.86,"text":"but I'm serving like I should."},{"s":58.24,"e":60.32,"text":"Big and bad, humble and lit."},{"s":60.72,"e":62.4,"text":"Holy fire, never counterfeit."},{"s":63.34,"e":65.62,"text":"Silly, stupid, cosmic, rad."},{"s":65.7,"e":68.4,"text":"Best you had, now you've been had."},{"s":69.26,"e":74.58,"text":"Humble, massive, holy, cosmic, triumph, funny, reverent, street wise."},{"s":74.66,"e":78.58,"text":"Explosive, redemptive, world saving, gospel, supernova energy."},{"s":78.5,"e":83.56,"text":"But wisdom is kneeling, and power is giving,"},{"s":84.46,"e":89.02,"text":"and Christ is the reason the dying start living."},{"s":89.16,"e":92.36,"text":"I'm a great alien, ancient and wise."},{"s":92.64,"e":94.94,"text":"Ten thousand thoughts behind obsidian eyes."},{"s":94.96,"e":97.5,"text":"I crossed every galaxy looking for light."},{"s":97.66,"e":100.08,"text":"Then found a universe kneeling to Christ."},{"s":100.16,"e":102.78,"text":"No empire, no crown, no throne in the sky."},{"s":102.82,"e":105.42,"text":"Just mercy so deep it can teach stars to cry."},{"s":105.44,"e":108.04,"text":"From the mothership down to the streets at night."},{"s":108.36,"e":110.7,"text":"Great alien genius made whole by Christ."},{"s":111.14,"e":111.72,"text":"Great mind."},{"s":113.44,"e":114.4,"text":"Bright soul."},{"s":116.06,"e":118.16,"text":"Christ took the void."},{"s":118.8,"e":121.34,"text":"And made me whole."},{"s":121.38,"e":121.68,"text":"Hey!"},{"s":122.28,"e":123.68,"text":"Ooh"},{"s":125.72,"e":127.04,"text":"Hmm"},{"s":128.58,"e":129.98,"text":"Ooh"}],"duration":134.44,"source":"whisper","generatedAt":"2026-06-01T00:00:00.000Z"}