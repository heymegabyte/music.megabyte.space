54.08,"line":51},{"w":"shit.”","s":154.08,"e":155.38,"line":51}],"lines":[{"s":2.86,"e":4.14,"text":"Yeah, yeah—"},{"s":8.46,"e":10.44,"text":"Walk in humble, still lit,"},{"s":13.54,"e":15.98,"text":"I don’t talk too much,"},{"s":15.98,"e":17.66,"text":"I just hit."},{"s":17.66,"e":21.62,"text":"I’m the shit, no debate, no myth,"},{"s":21.66,"e":24.56,"text":"God gave me gifts, I came with the lift."},{"s":24.62,"e":27.2,"text":"Whole room shift when I step in it,"},{"s":27.2,"e":29.98,"text":"I don’t half-do nothing, I’m built to commit."},{"s":30.62,"e":32.96,"text":"I’m the shit, still blessed, still kind,"},{"s":32.98,"e":35.84,"text":"Sharp in the soul, got fire in the mind."},{"s":35.84,"e":38.56,"text":"Fell down once, came back legit,"},{"s":38.64,"e":41.42,"text":"Look in the mirror like, “Bro, I’m the shit.”"},{"s":41.42,"e":44.24,"text":"I been through storms, still shine like chrome,"},{"s":44.24,"e":47.06,"text":"Turned cold nights into stepping stones."},{"s":47.12,"e":49.86,"text":"Had big doubt, had low-day fits,"},{"s":49.86,"e":52.64,"text":"Now my whole life got highlight clips."},{"s":52.64,"e":55.44,"text":"I don’t need hate, I don’t need clout,"},{"s":55.44,"e":58.34,"text":"I build real things, I figure it out."},{"s":58.34,"e":61.14,"text":"Hands on work, heart on flame,"},{"s":61.14,"e":64.04,"text":"Came from the pain and upgraded the name."},{"s":64.04,"e":66.86,"text":"No half-measures, full-send pressure,"},{"s":66.98,"e":69.64,"text":"Every scar turned into treasure."},{"s":69.66,"e":72.48,"text":"No fake flex, just real grit,"},{"s":72.54,"e":75.64,"text":"Whole soul saying, “I’m the shit.”"},{"s":75.64,"e":78.08,"text":"I’m the shit, no debate, no myth,"},{"s":78.12,"e":80.88,"text":"God gave me gifts, I came with the lift."},{"s":81.04,"e":83.64,"text":"Whole room shift when I step in it,"},{"s":83.64,"e":86.46,"text":"I don’t half-do nothing, I’m built to commit."},{"s":86.46,"e":89.42,"text":"I’m the shit, still blessed, still kind,"},{"s":89.52,"e":92.24,"text":"Sharp in the soul, got fire in the mind."},{"s":92.28,"e":95.02,"text":"Fell down once, came back legit,"},{"s":95.16,"e":97.86,"text":"Look in the mirror like, “Bro, I’m the shit.”"},{"s":97.86,"e":100.68,"text":"Not better than all, just better than fear,"},{"s":100.68,"e":103.48,"text":"I made it this far, so the mission is clear."},{"s":103.48,"e":106.24,"text":"I got bright plans, I got clean intent,"},{"s":106.24,"e":109.18,"text":"I got rent-due hunger with heaven-sent sense."},{"s":109.18,"e":111.9,"text":"They can laugh now, they can switch later,"},{"s":111.9,"e":114.74,"text":"I bless my haters, then I get greater."},{"s":114.74,"e":117.6,"text":"One deep breath, then I lock in quick,"},{"s":117.66,"e":120.76,"text":"Whole world better know I’m the shit."},{"s":120.76,"e":123.36,"text":"Lit with purpose, lit with grace,"},{"s":123.36,"e":126.22,"text":"Lit with sunlight on my face."},{"s":126.22,"e":129,"text":"Lit through struggle, lit through slips,"},{"s":129,"e":131.96,"text":"Lit like truth on holy lips."},{"s":131.98,"e":134.54,"text":"I’m the shit, no debate, no myth,"},{"s":134.58,"e":137.36,"text":"God gave me gifts, I came with the lift."},{"s":137.5,"e":140.1,"text":"Whole room shift when I step in it,"},{"s":140.1,"e":142.96,"text":"I don’t half-do nothing, I’m built to commit."},{"s":143.6,"e":145.88,"text":"I’m the shit, still blessed, still kind,"},{"s":145.94,"e":148.8,"text":"Sharp in the soul, got fire in the mind."},{"s":148.8,"e":151.5,"text":"Fell down once, came back legit,"},{"s":151.6,"e":155.38,"text":"Look in the mirror like, “Bro, I’m the shit.”"}],"duration":172.84,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.313Z","stats":{"whisperWords":396,"polishedWords":390,"matched":367,"matchRate":0.941}}