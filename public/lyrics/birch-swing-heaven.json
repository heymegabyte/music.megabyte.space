  "lines": [
    {
      "s": 14.65999984741211,
      "e": 18.239999771118164,
      "text": "When the world gets heavy I want"
    },
    {
      "s": 18.239999771118164,
      "e": 20.940000534057617,
      "text": "to climb high Swing on a birch"
    },
    {
      "s": 20.940000534057617,
      "e": 24.299999237060547,
      "text": "tree touch the sky Leave for a"
    },
    {
      "s": 24.299999237060547,
      "e": 26.559999465942383,
      "text": "minute but I won't stay gone Come"
    },
    {
      "s": 26.559999465942383,
      "e": 30.479999542236328,
      "text": "back to earth and keep moving on"
    },
    {
      "s": 42.7400016784668,
      "e": 45.7599983215332,
      "text": "Frost all bent trees and thought of"
    },
    {
      "s": 45.7599983215332,
      "e": 49.63999938964844,
      "text": "a boy Climbing for freedom climbing for"
    },
    {
      "s": 49.63999938964844,
      "e": 52.439998626708984,
      "text": "joy But life bends people like ice"
    },
    {
      "s": 52.439998626708984,
      "e": 55.18000030517578,
      "text": "bends trees Still we dream upward when"
    },
    {
      "s": 55.18000030517578,
      "e": 60.439998626708984,
      "text": "we need relief Not running forever just"
    },
    {
      "s": 60.439998626708984,
      "e": 65.41999816894531,
      "text": "breathing a while A small trip to"
    },
    {
      "s": 65.41999816894531,
      "e": 65.41999816894531,
      "text": "heaven"
    },
    {
      "s": 66.66000366210938,
      "e": 70.91999816894531,
      "text": "then back with a smile When the"
    },
    {
      "s": 70.91999816894531,
      "e": 73.77999877929688,
      "text": "world gets heavy I wanna climb high"
    },
    {
      "s": 73.77999877929688,
      "e": 76.91999816894531,
      "text": "Swing on a birch tree touch the"
    },
    {
      "s": 76.91999816894531,
      "e": 79.31999969482422,
      "text": "sky Leave for a minute but I"
    },
    {
      "s": 79.31999969482422,
      "e": 82.08000183105469,
      "text": "won't stay gone Come back to earth"
    },
    {
      "s": 82.08000183105469,
      "e": 83.80999755859375,
      "text": "and keep moving on"
    },
    {
      "s": 100.81999969482422,
      "e": 102.81999969482422,
      "text": "Come back to earth and keep moving"
    },
    {
      "s": 102.81999969482422,
