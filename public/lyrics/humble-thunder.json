8.08,"e":148.32,"line":51},{"w":"up?","s":148.56,"e":148.9,"line":51},{"w":"Started","s":149.76,"e":149.84,"line":52},{"w":"from","s":149.76,"e":150.1,"line":52},{"w":"the","s":150.1,"e":150.64,"line":52},{"w":"top,","s":150.64,"e":150.76,"line":52},{"w":"Now","s":152.36,"e":153.32,"line":53},{"w":"I’m","s":153.32,"e":153.56,"line":53},{"w":"here.","s":153.8,"e":154.72,"line":53},{"w":"Not","s":155.24,"e":156.2,"line":54},{"w":"lost,","s":156.2,"e":156.78,"line":54},{"w":"not","s":162.08,"e":162.32,"line":54},{"w":"stuck—","s":162.32,"e":162.74,"line":54},{"w":"So","s":180.08,"e":180.68,"line":55},{"w":"what’s","s":180.68,"e":180.83,"line":55},{"w":"up?","s":180.98,"e":181.06,"line":55}],"lines":[{"s":2.44,"e":3.02,"text":"Yeah—"},{"s":5.72,"e":7.46,"text":"I started from the top,"},{"s":8.64,"e":10,"text":"Now I’m here."},{"s":11.04,"e":12.58,"text":"So what’s up?"},{"s":13,"e":15.42,"text":"I started from the top and now I’m here,"},{"s":16.26,"e":19.26,"text":"Whole room quiet when I walk near."},{"s":19.56,"e":22.82,"text":"I ain’t fall off, I just dropped down,"},{"s":23.28,"e":26.44,"text":"Touched earth, then I shook town."},{"s":26.5,"e":28.98,"text":"Started from the top and now I’m here,"},{"s":30.12,"e":33.36,"text":"Still got fire, still think clear."},{"s":33.64,"e":36.78,"text":"Look at me now, no fear, no bluff—"},{"s":37.34,"e":40.2,"text":"I’m right here, so what’s up?"},{"s":40.72,"e":42.26,"text":"I came in blessed, no ladder to climb,"},{"s":42.26,"e":44.06,"text":"Already had thunder tucked in my spine."},{"s":43.98,"e":45.66,"text":"They said, “Stay humble,” I said, “I try,”"},{"s":45.66,"e":47.42,"text":"But the sun don’t whisper when it lights up the sky."},{"s":47.42,"e":49.2,"text":"I took the long road just to prove I could,"},{"s":49.2,"e":50.88,"text":"Left gold floors for the neighborhood."},{"s":50.88,"e":52.62,"text":"Had to touch pain, had to learn dust,"},{"s":52.62,"e":54.36,"text":"Had to know love from the ones I trust."},{"s":54.36,"e":56.08,"text":"I didn’t rise, I descended with grace,"},{"s":56.08,"e":57.74,"text":"Brought a little heaven to a regular place."},{"s":57.74,"e":59.52,"text":"Now the beat knock loud and the bass too tough,"},{"s":59.52,"e":62.68,"text":"I’m right here, so what’s up?"},{"s":63.1,"e":65.68,"text":"I started from the top and now I’m here,"},{"s":66.3,"e":69.62,"text":"Whole room quiet when I walk near."},{"s":69.62,"e":72.55,"text":"I ain’t fall off, I just dropped down,"},{"s":73.3,"e":76.34,"text":"Touched earth, then I shook town."},{"s":76.52,"e":79.14,"text":"Started from the top and now I’m here,"},{"s":80.25,"e":83.22,"text":"Still got fire, still think clear."},{"s":83.34,"e":86.86,"text":"Look at me now, no fear, no bluff—"},{"s":87.41,"e":90.24,"text":"I’m right here, so what’s up?"},{"s":90.66,"e":93.28,"text":"I don’t need a crown, I don’t chase a throne,"},{"s":93.28,"e":95.12,"text":"I build my kingdom out of flesh and bone."},{"s":95.04,"e":96.78,"text":"Every little setback taught me game,"},{"s":96.78,"e":98.48,"text":"Every closed door learned my name."},{"s":98.48,"e":100.06,"text":"I’m not impressed by the smoke and lights,"},{"s":100.06,"e":101.76,"text":"I been too close to the source of bright."},{"s":101.76,"e":103.06,"text":"Came from the high, walked through the low,"},{"s":103.06,"e":104.8,"text":"Now I got roots where the real ones grow."},{"s":104.8,"e":107.3,"text":"Top floor spirit, basement grind,"},{"s":108.82,"e":110.82,"text":"Million-watt soul with a focused mind."},{"s":111.32,"e":114.66,"text":"Sky in my chest, dirt on my cuffs,"},{"s":114.94,"e":119.56,"text":"I’m right here—so what’s up?"},{"s":122.02,"e":124.2,"text":"I started from the top and now I’m here,"},{"s":125,"e":128.28,"text":"Whole room quiet when I walk near."},{"s":128.28,"e":131.74,"text":"I ain’t fall off, I just dropped down,"},{"s":132,"e":135,"text":"Touched earth, then I shook town."},{"s":135.22,"e":137.84,"text":"Started from the top and now I’m here,"},{"s":138.54,"e":141.96,"text":"Still got fire, still think clear."},{"s":142.04,"e":145.48,"text":"Look at me now, no fear, no bluff—"},{"s":145.48,"e":148.9,"text":"I’m right here, so what’s up?"},{"s":149.76,"e":150.76,"text":"Started from the top,"},{"s":152.36,"e":154.72,"text":"Now I’m here."},{"s":155.24,"e":162.74,"text":"Not lost, not stuck—"},{"s":180.08,"e":181.06,"text":"So what’s up?"}],"duration":181.24,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.311Z","stats":{"whisperWords":429,"polishedWords":415,"matched":385,"matchRate":0.928}}