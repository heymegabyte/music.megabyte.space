"s":184.78,"e":185.5,"line":42},{"w":"If","s":185.5,"e":186.54,"line":43},{"w":"mercy","s":186.54,"e":187.06,"line":43},{"w":"is","s":187.06,"e":188.12,"line":43},{"w":"real,","s":188.12,"e":188.86,"line":43},{"w":"it","s":188.86,"e":189.88,"line":44},{"w":"reaches","s":189.88,"e":190.7,"line":44},{"w":"the","s":190.7,"e":191.62,"line":44},{"w":"pit.","s":191.62,"e":192.38,"line":44},{"w":"If","s":192.38,"e":193.36,"line":45},{"w":"love","s":193.36,"e":193.82,"line":45},{"w":"is","s":193.82,"e":194.3,"line":45},{"w":"alive,","s":195.04,"e":195.86,"line":45},{"w":"it","s":195.86,"e":197.12,"line":46},{"w":"doesn’t","s":197.12,"e":197.66,"line":46},{"w":"quit.","s":198.2,"e":199.22,"line":46}],"lines":[{"s":2.58,"e":2.78,"text":"Yeah—"},{"s":8.6,"e":11.28,"text":"If mercy got a border,"},{"s":12.96,"e":17.46,"text":"then mercy ain’t complete."},{"s":32.98,"e":36.82,"text":"They heard about a beast down burning in the deep,"},{"s":36.92,"e":40.34,"text":"Then turned the page and went back to sleep."},{"s":40.54,"e":43.64,"text":"Horned in the smoke, chained in the flame,"},{"s":44.06,"e":47.02,"text":"Everybody pointing, nobody took blame."},{"s":47.02,"e":50.64,"text":"If one creature cries and the whole world knows,"},{"s":50.64,"e":53.9,"text":"What kind of garden lets that pain grow?"},{"s":53.9,"e":57.4,"text":"You can call him fallen, you can call him wrong,"},{"s":57.4,"e":60.78,"text":"But leaving pain forever is a cruel old song."},{"s":60.78,"e":62.92,"text":"No creature left in fire,"},{"s":63.82,"e":67.04,"text":"No soul beneath the stone."},{"s":67.22,"e":69.76,"text":"If love is getting higher,"},{"s":70.28,"e":74.32,"text":"Then nobody burns alone."},{"s":74.38,"e":76.6,"text":"The whole world heard the thunder,"},{"s":76.98,"e":80.84,"text":"The whole world closed the door."},{"s":80.84,"e":83.68,"text":"No creature left in fire—"},{"s":84.88,"e":89.96,"text":"Not one beast anymore."},{"s":95.18,"e":98.6,"text":"Justice without mercy turns cold in the hand,"},{"s":98.6,"e":101.94,"text":"Rules without love don’t heal the land."},{"s":101.94,"e":105.34,"text":"If heaven is holy and light is true,"},{"s":105.34,"e":108.62,"text":"Then compassion gotta reach the monster too."},{"s":108.62,"e":112.24,"text":"Not praising the darkness, not kissing the chain,"},{"s":112.24,"e":115.56,"text":"Just saying forever pain is still pain."},{"s":115.56,"e":119.1,"text":"If we want peace, then we better get brave,"},{"s":119.1,"e":122.46,"text":"Pull every lost thing out of the grave."},{"s":122.5,"e":126.04,"text":"Fair don’t fix it, fear don’t heal,"},{"s":126.04,"e":129.42,"text":"Love gets loud when the suffering’s real."},{"s":129.42,"e":132.8,"text":"If one stays burning while the choirs sing,"},{"s":132.8,"e":136.18,"text":"Then mercy still ain’t spread its wings."},{"s":136.18,"e":138.22,"text":"No creature left in fire,"},{"s":139.08,"e":142.4,"text":"No soul beneath the stone."},{"s":142.6,"e":145.22,"text":"If love is getting higher,"},{"s":145.7,"e":149.72,"text":"Then nobody burns alone."},{"s":150,"e":151.98,"text":"The whole world heard the thunder,"},{"s":152.48,"e":156.26,"text":"The whole world closed the door."},{"s":156.26,"e":158.88,"text":"No creature left in fire—"},{"s":160.28,"e":165.38,"text":"Not one beast anymore."},{"s":170.54,"e":175.22,"text":"Drag the chains out, cool the coal,"},{"s":175.22,"e":178.24,"text":"Wash the smoke from every soul."},{"s":178.34,"e":182.08,"text":"No more cages, no more screams,"},{"s":182.08,"e":185.5,"text":"No more nightmares sold as dreams."},{"s":185.5,"e":188.86,"text":"If mercy is real,"},{"s":188.86,"e":192.38,"text":"it reaches the pit."},{"s":192.38,"e":195.86,"text":"If love is alive,"},{"s":195.86,"e":199.22,"text":"it doesn’t quit."}],"duration":219.6,"source":"whisper-aligned","generatedAt":"2026-05-25T06:38:40.299Z","stats":{"whisperWords":304,"polishedWords":296,"matched":289,"matchRate":0.976}}