{
  "printWidth": 110,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.md", "*.html"],
      "options": { "printWidth": 100 }
    },
    {
      "files": ["*.json", "*.jsonc"],
      "options": { "printWidth": 80 }
    }
  ]
}
