# ── Verification / debug screenshots & captures (repo root + anywhere) ──
# These accumulate from Playwright + manual QA. Keep them out of git.
/*.png
/*.jpeg
/*.jpg
/*.webp
/*.gif
/*.mp4
/*.mov
/verify-*.png
/viz-picker-*.png
hero-*.png
*-before.png
*-after.png
*-final*.png

# ── One-off probe / scratch scripts ────────────────────────────────────
/probe*.mjs
/scripts/_*.mjs
/_*.mjs
/_*.js

# ── Suno extraction artifacts — regeneratable via scripts/fetch-suno-metadata.mjs;
#    ~3 MB of raw prompt/tag data that bloats the diff. ───────────────────
/data/suno-feed.json
/data/suno-matches.json
/data/whisper-cache/

# ── Local audit scratch files ──────────────────────────────────────────
_sks_*.json
_PROD.txt
_VERDICT.txt

# ── Relocated large media: print masters + orphaned video (kept local, never web-served) ──
/_archive/
